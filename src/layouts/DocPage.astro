---
import BaseLayout from "./BaseLayout.astro";

type Props = {
  title: string;
  eyebrow?: string;
  description?: string;
};

const { title, eyebrow = "Legal", description } = Astro.props;
---

<BaseLayout seo={{ title: `${title} — South Van FC`, description }}>
  <section class="doc-hero">
    <div class="accent-bar" aria-hidden="true"></div>
    <div class="hero-inner">
      <span class="eyebrow">{eyebrow}</span>
      <h1 class="hero-title">{title}</h1>
    </div>
    <div class="hero-stripe" aria-hidden="true"></div>
  </section>

  <section class="doc-body">
    <div class="doc-inner prose">
      <slot />
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .doc-hero {
    background: #011f4a;
    padding: 72px 80px 0;
    position: relative;
    overflow: hidden;
  }
  .accent-bar {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: linear-gradient(180deg, #e8b430 0%, rgba(232, 180, 48, 0) 100%);
  }
  .hero-inner {
    position: relative;
    z-index: 2;
    padding-bottom: 56px;
  }
  .eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #e8b430;
    display: block;
    margin-bottom: 14px;
  }
  .hero-title {
    font-size: clamp(48px, 5vw, 72px);
    line-height: 0.9;
    letter-spacing: 2px;
    color: #fff;
    margin: 0;
  }
  .hero-stripe {
    height: 6px;
    background: repeating-linear-gradient(
      90deg,
      #e8b430 0,
      #e8b430 40px,
      transparent 40px,
      transparent 48px
    );
    position: relative;
    z-index: 2;
  }

  /* ── Body ── */
  .doc-body {
    background: #f7f8fc;
    padding: 64px 80px;
  }
  .doc-inner {
    max-width: 820px;
    margin: 0 auto;
  }

  /* ── Prose ── */
  .prose :global(h1) {
    display: none;
  }
  .prose :global(h2) {
    font-size: 28px;
    letter-spacing: 1px;
    color: #011f4a;
    margin: 48px 0 16px;
    padding-bottom: 10px;
    border-bottom: 2px solid #e8b430;
  }
  .prose :global(h3) {
    font-size: 15px;
    font-weight: 700;
    color: #011f4a;
    margin: 28px 0 10px;
  }
  .prose :global(p) {
    font-size: 15px;
    line-height: 1.8;
    color: #3a4566;
    margin: 0 0 16px;
  }
  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 24px;
    margin: 0 0 16px;
  }
  .prose :global(li) {
    font-size: 15px;
    line-height: 1.8;
    color: #3a4566;
    margin-bottom: 6px;
  }
  .prose :global(strong) {
    color: #011f4a;
    font-weight: 700;
  }
  .prose :global(em) {
    font-style: italic;
  }
  .prose :global(a) {
    color: #013478;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s;
  }
  .prose :global(a:hover) {
    color: #e8b430;
  }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid #dde1ef;
    margin: 40px 0;
  }
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
    margin: 24px 0;
  }
  .prose :global(th) {
    background: #011f4a;
    color: #fff;
    font-weight: 700;
    text-align: left;
    padding: 10px 16px;
  }
  .prose :global(td) {
    padding: 10px 16px;
    color: #3a4566;
    border-bottom: 1px solid #dde1ef;
  }
  .prose :global(tr:nth-child(even) td) {
    background: #eef0f7;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .doc-hero {
      padding: 56px 28px 0;
    }
    .doc-body {
      padding: 44px 28px;
    }
    .prose :global(table) {
      display: block;
      overflow-x: auto;
    }
  }
</style>
