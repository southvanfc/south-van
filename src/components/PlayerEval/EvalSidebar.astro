---
// src/components/academy/EvalSidebar.astro

const steps = [
  {
    num: "01",
    title: "Submit This Form",
    body: "We'll match you to the right evaluation format for your age and level.",
  },
  {
    num: "02",
    title: "We'll Confirm",
    body: "A coach will reach out within 48 hours to schedule your session.",
  },
  {
    num: "03",
    title: "Attend Your Session",
    body: "Come ready to play. We evaluate in a live football environment.",
  },
  {
    num: "04",
    title: "Receive Feedback",
    body: "Written report: scores, strengths, and clear next steps.",
  },
];

const eligibility = [
  "Open to all ages and ability levels",
  "Any club or no club affiliation",
  "Players must bring their own kit",
  "Parent/guardian consent required for U18",
  "No prior trial experience needed",
];

const pillars = [
  { icon: "⚽", label: "Technical" },
  { icon: "🧠", label: "Tactical" },
  { icon: "⚡", label: "Physical" },
  { icon: "🏆", label: "Mental" },
];
---

<aside class="sidebar">
  <!-- What to expect -->
  <div class="scard">
    <div class="scard-title">What to Expect</div>
    <div class="steps">
      {
        steps.map(({ num, title, body }) => (
          <div class="step">
            <span class="step-num">{num}</span>
            <div>
              <div class="step-title">{title}</div>
              <div class="step-body">{body}</div>
            </div>
          </div>
        ))
      }
    </div>
  </div>

  <!-- Eligibility -->
  <div class="scard scard-navy">
    <div class="scard-title scard-title-w">Eligibility</div>
    <div class="elig">
      {
        eligibility.map((item) => (
          <div class="elig-item">
            <svg
              width="13"
              height="13"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
            >
              <path d="M20 6L9 17l-5-5" />
            </svg>
            {item}
          </div>
        ))
      }
    </div>
  </div>

  <!-- What we assess -->
  <div class="scard">
    <div class="scard-title">What We Assess</div>
    <div class="pillar-grid">
      {
        pillars.map(({ icon, label }) => (
          <div class="pillar">
            <span class="pillar-icon">{icon}</span>
            <span class="pillar-label">{label}</span>
          </div>
        ))
      }
    </div>
    <p class="scard-note">
      Scored 1–5 across all four pillars. Used for development only — never to
      compare players.
    </p>
  </div>

  <!-- Contact nudge -->
  <div class="scard scard-dashed">
    <p class="scard-q">Have a question first?</p>
    <a href="mailto:southvanfc@gmail.com" class="email-link">
      Email Us Directly
      <svg
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
      >
    </a>
  </div>
</aside>

<style>
  .sidebar {
    position: sticky;
    top: 88px;
    align-self: start;
    padding: 44px 28px 44px 64px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  /* Cards */
  .scard {
    background: #fff;
    border: 1px solid #eef0f7;
    border-radius: 12px;
    padding: 22px;
  }
  .scard-navy {
    background: #013478;
    border-color: transparent;
  }
  .scard-dashed {
    background: transparent;
    border: 1.5px dashed #d0d5e8;
  }

  .scard-title {
    font-family: "Inter Variable", sans-serif;
    font-size: 17px;
    letter-spacing: 1px;
    color: #011f4a;
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 2px solid #e8b430;
  }
  .scard-title-w {
    color: #fff;
  }

  /* Steps */
  .steps {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .step {
    display: flex;
    gap: 11px;
    align-items: flex-start;
  }
  .step-num {
    font-family: "Inter Variable", sans-serif;
    font-size: 20px;
    color: #e8b430;
    flex-shrink: 0;
    width: 26px;
    text-align: right;
    line-height: 1;
    margin-top: 1px;
  }
  .step-title {
    font-size: 12px;
    font-weight: 700;
    color: #011f4a;
    margin-bottom: 3px;
  }
  .step-body {
    font-size: 11px;
    color: #6b7a9e;
    line-height: 1.55;
  }

  /* Eligibility */
  .elig {
    display: flex;
    flex-direction: column;
    gap: 9px;
  }
  .elig-item {
    display: flex;
    gap: 8px;
    align-items: flex-start;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.5;
  }
  .elig-item svg {
    flex-shrink: 0;
    color: #e8b430;
    margin-top: 1px;
  }

  /* Pillars */
  .pillar-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 7px;
    margin-bottom: 12px;
  }
  .pillar {
    display: flex;
    align-items: center;
    gap: 7px;
    background: #f7f8fc;
    border-radius: 7px;
    padding: 9px 10px;
  }
  .pillar-icon {
    font-size: 16px;
  }
  .pillar-label {
    font-size: 11px;
    font-weight: 600;
    color: #013478;
  }
  .scard-note {
    font-size: 11px;
    color: #6b7a9e;
    line-height: 1.55;
  }

  /* Contact nudge */
  .scard-q {
    font-size: 12px;
    color: #3d4d6e;
    font-weight: 500;
    margin-bottom: 10px;
  }
  .email-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 11px 16px;
    border: 1.5px solid #013478;
    border-radius: 7px;
    font-size: 13px;
    font-weight: 600;
    color: #013478;
    text-decoration: none;
    transition:
      background 0.2s,
      color 0.2s;
  }
  .email-link:hover {
    background: #013478;
    color: #fff;
  }

  @media (max-width: 1100px) {
    .sidebar {
      padding: 44px 20px 44px 36px;
    }
  }
  @media (max-width: 960px) {
    .sidebar {
      position: static;
      padding: 36px 28px;
    }
  }
</style>
