---
// src/components/academy/EvalMeta.astro

const eligibility = [
  "Open to all ages and ability levels",
  "Any club or no club affiliation",
  "Players must bring their own kit",
  "Parent/guardian consent required for U18",
  "No prior trial experience needed",
];

const pillars = [
  {
    icon: "⚽",
    label: "Technical",
    desc: "Ball control, passing, technique under pressure",
  },
  {
    icon: "🧠",
    label: "Tactical",
    desc: "Decision making, positioning, game reading",
  },
  {
    icon: "⚡",
    label: "Physical",
    desc: "Speed, endurance, strength and agility",
  },
  {
    icon: "🏆",
    label: "Mental",
    desc: "Focus, resilience, coachability and attitude",
  },
];
---

<section class="meta">
  <div class="meta-grid">
    <!-- Eligibility -->
    <div class="meta-col">
      <div class="col-eyebrow">Eligibility</div>
      <ul class="elig-list">
        {
          eligibility.map((item) => (
            <li class="elig-item">
              <svg
                width="12"
                height="12"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
              >
                <path d="M20 6L9 17l-5-5" />
              </svg>
              {item}
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Divider -->
    <div class="meta-divider" aria-hidden="true"></div>

    <!-- What we assess -->
    <div class="meta-col">
      <div class="col-eyebrow">What We Assess</div>
      <p class="assess-note">
        Every player is scored 1–5 across four pillars. Results are used for
        development only.
      </p>
      <div class="pillar-row">
        {
          pillars.map(({ icon, label, desc }) => (
            <div class="pillar">
              <div class="pillar-top">
                <span class="pillar-icon">{icon}</span>
                <span class="pillar-label">{label}</span>
              </div>
              <p class="pillar-desc">{desc}</p>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Divider -->
    <div class="meta-divider" aria-hidden="true"></div>

    <!-- Contact -->
    <div class="meta-col meta-col-sm">
      <div class="col-eyebrow">Questions?</div>
      <p class="contact-body">
        Have a question before submitting? Reach out directly and a coach will
        respond.
      </p>
      <a href="mailto:southvanfc@gmail.com" class="email-btn">
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          ><path
            d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
          ></path><polyline points="22,6 12,13 2,6"></polyline></svg
        >
        southvanfc@gmail.com
      </a>
      <p class="response-note">
        <svg
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          ><circle cx="12" cy="12" r="10"></circle><path d="M12 6v6l4 2"
          ></path></svg
        >
        Typically respond within 24 hours
      </p>
    </div>
  </div>
</section>

<style>
  .meta {
    background: #fff;
    border-bottom: 1px solid #eef0f7;
    padding: 48px 80px;
  }

  .meta-grid {
    display: grid;
    grid-template-columns: 1fr 1px 1.8fr 1px 1fr;
    gap: 0 48px;
    align-items: start;
  }

  .meta-divider {
    background: #eef0f7;
    align-self: stretch;
  }

  /* Column shared */
  .meta-col {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .meta-col-sm {
    gap: 12px;
  }

  .col-eyebrow {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #e8b430;
    padding-bottom: 10px;
    border-bottom: 1px solid #eef0f7;
  }

  /* Eligibility */
  .elig-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }
  .elig-item {
    display: flex;
    align-items: flex-start;
    gap: 9px;
    font-size: 13px;
    color: #3d4d6e;
    line-height: 1.5;
  }
  .elig-item svg {
    flex-shrink: 0;
    color: #013478;
    margin-top: 2px;
  }

  /* Pillars */
  .assess-note {
    font-size: 12px;
    color: #6b7a9e;
    line-height: 1.6;
    margin-top: -4px;
  }
  .pillar-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }
  .pillar {
    background: #f7f8fc;
    border: 1px solid #eef0f7;
    border-radius: 8px;
    padding: 12px 14px;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .pillar-top {
    display: flex;
    align-items: center;
    gap: 7px;
  }
  .pillar-icon {
    font-size: 15px;
  }
  .pillar-label {
    font-size: 12px;
    font-weight: 700;
    color: #011f4a;
  }
  .pillar-desc {
    font-size: 11px;
    color: #6b7a9e;
    line-height: 1.5;
  }

  /* Contact */
  .contact-body {
    font-size: 13px;
    color: #6b7a9e;
    line-height: 1.6;
    margin-top: -4px;
  }
  .email-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
    color: #013478;
    text-decoration: none;
    border: 1.5px solid #013478;
    border-radius: 7px;
    padding: 10px 16px;
    transition:
      background 0.2s,
      color 0.2s;
    width: fit-content;
  }
  .email-btn:hover {
    background: #013478;
    color: #fff;
  }
  .response-note {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: #6b7a9e;
  }
  .response-note svg {
    flex-shrink: 0;
  }

  @media (max-width: 960px) {
    .meta {
      padding: 40px 28px;
    }
    .meta-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .meta-divider {
      display: none;
    }
    .pillar-row {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 480px) {
    .pillar-row {
      grid-template-columns: 1fr;
    }
  }
</style>
