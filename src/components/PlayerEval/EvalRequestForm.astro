---
// src/components/PlayerEval/EvalRequestForm.astro
// Field names match submit-evaluation.ts exactly.
// Step 1: Player Details | Parent / Guardian | Position & Foot
// Step 2: Training & Competition | Player Background | Goals & Referral
---

<form action="/api/submit-evaluation/" method="POST" id="eval-form">
  <!-- Honeypot — inside form so it actually submits with the POST -->
  <input
    type="text"
    name="company"
    autocomplete="off"
    tabindex="-1"
    aria-hidden="true"
    style="position:absolute;left:-9999px;opacity:0;pointer-events:none;"
  />

  <!-- ── Progress indicator ──────────────────── -->
  <div class="step-indicator" aria-label="Form progress">
    <div class="step-pip" data-pip="1">
      <div class="step-circle">1</div>
      <span class="step-label">Player &amp; Parent</span>
    </div>
    <div class="step-connector"></div>
    <div class="step-pip" data-pip="2">
      <div class="step-circle">2</div>
      <span class="step-label">Background &amp; Goals</span>
    </div>
  </div>

  <!-- ════════════════════════════════════════════
       STEP 1 — Player identity + contact
       ════════════════════════════════════════════ -->
  <div class="form-step" data-step="1">
    <!-- ── 01 PLAYER DETAILS ──────────────────── -->
    <div class="fsec">
      <div class="fsec-head">
        <span class="fsec-num">01</span>
        <div>
          <div class="fsec-label">Player Details</div>
          <div class="fsec-hint">
            Basic information about the player being evaluated.
          </div>
        </div>
      </div>
      <div class="fgrid fgrid-2">
        <div class="f">
          <label class="f-label" for="full_name"
            >Full Name <span class="f-req">*</span></label
          >
          <input
            class="f-input"
            id="full_name"
            name="full_name"
            type="text"
            placeholder="Player's full name"
          />
          <span class="f-err" id="full_name-error" aria-live="polite"></span>
        </div>
        <div class="f">
          <label class="f-label" for="dob"
            >Date of Birth <span class="f-req">*</span></label
          >
          <input class="f-input" id="dob" name="dob" type="date" />
          <span class="f-err" id="dob-error" aria-live="polite"></span>
        </div>
        <div class="f">
          <label class="f-label" for="age_group"
            >Age Group <span class="f-req">*</span></label
          >
          <select class="f-select" id="age_group" name="age_group">
            <option value="" disabled selected>Select age group</option>
            <option value="u8-u11">U8 – U11</option>
            <option value="u12-u15">U12 – U15</option>
            <option value="u15-u18">U15 – U18</option>
          </select>
          <span class="f-err" id="age_group-error" aria-live="polite"></span>
        </div>
        <div class="f">
          <label class="f-label" for="club"
            >Current Club <span class="f-opt">Optional</span></label
          >
          <input
            class="f-input"
            id="club"
            name="club"
            type="text"
            placeholder="Leave blank if no club"
          />
        </div>
        <div class="f">
          <label class="f-label" for="years_playing"
            >Years Playing Soccer <span class="f-req">*</span></label
          >
          <select class="f-select" id="years_playing" name="years_playing">
            <option value="" disabled selected>Select range</option>
            <option value="less-than-1">Less than 1 year</option>
            <option value="1-2">1 – 2 years</option>
            <option value="3-5">3 – 5 years</option>
            <option value="6-9">6 – 9 years</option>
            <option value="10+">10+ years</option>
          </select>
          <span class="f-err" id="years_playing-error" aria-live="polite"
          ></span>
        </div>
        <div class="f">
          <label class="f-label" for="school_grade"
            >School Grade <span class="f-opt">Optional</span></label
          >
          <select class="f-select" id="school_grade" name="school_grade">
            <option value="" disabled selected>Select grade</option>
            <option value="k">Kindergarten</option>
            <option value="1">Grade 1</option>
            <option value="2">Grade 2</option>
            <option value="3">Grade 3</option>
            <option value="4">Grade 4</option>
            <option value="5">Grade 5</option>
            <option value="6">Grade 6</option>
            <option value="7">Grade 7</option>
            <option value="8">Grade 8</option>
            <option value="9">Grade 9</option>
            <option value="10">Grade 10</option>
            <option value="11">Grade 11</option>
            <option value="12">Grade 12</option>
          </select>
        </div>
      </div>
    </div>

    <!-- ── 02 PARENT / GUARDIAN ───────────────── -->
    <div class="fsec">
      <div class="fsec-head">
        <span class="fsec-num">02</span>
        <div>
          <div class="fsec-label">Parent / Guardian</div>
          <div class="fsec-hint">
            Required for all players under 18. This is our primary contact for
            scheduling and updates.
          </div>
        </div>
      </div>
      <div class="fgrid fgrid-2">
        <div class="f">
          <label class="f-label" for="parent_name"
            >Full Name <span class="f-req">*</span></label
          >
          <input
            class="f-input"
            id="parent_name"
            name="parent_name"
            type="text"
            placeholder="Parent or guardian full name"
          />
          <span class="f-err" id="parent_name-error" aria-live="polite"></span>
        </div>
        <div class="f">
          <label class="f-label" for="parent_relationship"
            >Relationship to Player <span class="f-req">*</span></label
          >
          <select
            class="f-select"
            id="parent_relationship"
            name="parent_relationship"
          >
            <option value="" disabled selected>Select relationship</option>
            <option value="mother">Mother</option>
            <option value="father">Father</option>
            <option value="guardian">Legal Guardian</option>
            <option value="other">Other</option>
          </select>
          <span class="f-err" id="parent_relationship-error" aria-live="polite"
          ></span>
        </div>
        <div class="f">
          <label class="f-label" for="parent_email"
            >Email Address <span class="f-req">*</span></label
          >
          <input
            class="f-input"
            id="parent_email"
            name="parent_email"
            type="email"
            placeholder="parent@email.com"
          />
          <span class="f-err" id="parent_email-error" aria-live="polite"></span>
        </div>
        <div class="f">
          <label class="f-label" for="parent_phone"
            >Phone Number <span class="f-req">*</span></label
          >
          <input
            class="f-input"
            id="parent_phone"
            name="parent_phone"
            type="tel"
            placeholder="+1 (604) 000-0000"
          />
          <span class="f-err" id="parent_phone-error" aria-live="polite"></span>
        </div>
      </div>
    </div>

    <!-- ── 03 PLAYING POSITION ────────────────── -->
    <div class="fsec">
      <div class="fsec-head">
        <span class="fsec-num">03</span>
        <div>
          <div class="fsec-label">Playing Position</div>
          <div class="fsec-hint">
            Select primary position(s) and dominant foot.
          </div>
        </div>
      </div>
      <div class="fgrid fgrid-1">
        <!-- Position tiles -->
        <div class="f">
          <label class="f-label"
            >Primary Position(s) <span class="f-req">*</span></label
          >
          <p class="f-hint">Select all that apply.</p>
          <div class="pos-grid">
            {
              [
                { value: "GK", label: "Goalkeeper", icon: "🧤" },
                { value: "Defender", label: "Defender", icon: "🛡️" },
                { value: "Midfielder", label: "Midfielder", icon: "⚙️" },
                { value: "Winger", label: "Winger", icon: "⚡" },
                { value: "Striker", label: "Striker", icon: "⚽" },
              ].map(({ value, label, icon }) => (
                <label class="pos-tile">
                  <input type="checkbox" name="positions" value={value} />
                  <span class="pos-icon">{icon}</span>
                  <span class="pos-lbl">{label}</span>
                  <span class="pos-check">
                    <svg
                      width="10"
                      height="10"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3.5"
                      stroke-linecap="round"
                    >
                      <path d="M20 6L9 17l-5-5" />
                    </svg>
                  </span>
                </label>
              ))
            }
          </div>
          <span class="f-err" id="positions-error" aria-live="polite"></span>
        </div>

        <!-- Dominant foot -->
        <div class="f">
          <label class="f-label"
            >Dominant Foot <span class="f-req">*</span></label
          >
          <div class="foot-row">
            {
              [
                { value: "right", label: "Right" },
                { value: "left", label: "Left" },
                { value: "both", label: "Both" },
              ].map(({ value, label }) => (
                <label class="rtile">
                  <input type="radio" name="preferred_foot" value={value} />
                  <span class="rtile-lbl">{label}</span>
                </label>
              ))
            }
          </div>
          <span class="f-err" id="preferred_foot-error" aria-live="polite"
          ></span>
        </div>
      </div>
    </div>
  </div><!-- /form-step[1] -->

  <!-- ── STEP 1 NAV ─────────────────────────── -->
  <div class="f-nav" id="step-nav-1">
    <div class="f-note">
      <p class="caption">
        Fields marked <span class="f-req">*</span> are required.
      </p>
      <p class="caption">We respond within 48 hours.</p>
    </div>
    <button type="button" class="f-btn" id="next-btn">
      Continue
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
      >
        <path d="M5 12h14M12 5l7 7-7 7"></path>
      </svg>
    </button>
  </div>

  <!-- ════════════════════════════════════════════
       STEP 2 — Training, background, goals
       ════════════════════════════════════════════ -->
  <div class="form-step" data-step="2">
    <!-- ── 04 TRAINING & COMPETITION ──────────── -->
    <div class="fsec">
      <div class="fsec-head">
        <span class="fsec-num">04</span>
        <div>
          <div class="fsec-label">Training &amp; Competition</div>
          <div class="fsec-hint">
            Current training load and competitive level.
          </div>
        </div>
      </div>
      <div class="fgrid fgrid-1">
        <div class="f">
          <label class="f-label" for="training_hours"
            >Weekly Training Hours <span class="f-req">*</span></label
          >
          <p class="f-hint">
            Outside of school PE — include all club sessions, personal training,
            and pickup.
          </p>
          <select
            class="f-select"
            id="training_hours"
            name="training_hours"
            required
          >
            <option value="" disabled selected>Select range</option>
            <option value="less-than-2">Less than 2 hours</option>
            <option value="2-4">2 – 4 hours</option>
            <option value="4-6">4 – 6 hours</option>
            <option value="6-8">6 – 8 hours</option>
            <option value="8+">8+ hours</option>
          </select>
        </div>

        <div class="f">
          <label class="f-label" for="competition_level"
            >Current Competition Level <span class="f-req">*</span></label
          >
          <p class="f-hint">
            Select the highest level this player currently competes at in
            Vancouver / Lower Mainland.
          </p>
          <select
            class="f-select"
            id="competition_level"
            name="competition_level"
            required
          >
            <option value="" disabled selected>Select level</option>
            <option value="bcspl">BCSPL (BC Soccer Premier League)</option>
            <option value="metro">Metro</option>
            <option value="gold">Gold</option>
            <option value="silver">Silver</option>
            <option value="bronze">Bronze</option>
            <option value="recreational">Recreational / House League</option>
            <option value="school-only">School team only</option>
            <option value="no-team">Not currently on a team</option>
          </select>
        </div>

        <div class="f">
          <label class="f-label" for="other_sports"
            >Other Sports Currently Played <span class="f-opt">Optional</span
            ></label
          >
          <p class="f-hint">
            List any other sports the player actively trains or competes in.
          </p>
          <input
            class="f-input"
            id="other_sports"
            name="other_sports"
            type="text"
            placeholder="e.g. Basketball, ice hockey, swimming"
          />
        </div>
      </div>
    </div>

    <!-- ── 05 PLAYER BACKGROUND ───────────────── -->
    <div class="fsec">
      <div class="fsec-head">
        <span class="fsec-num">05</span>
        <div>
          <div class="fsec-label">Player Background</div>
          <div class="fsec-hint">
            Helps us tailor every session to where the player is right now.
          </div>
        </div>
      </div>
      <div class="fgrid fgrid-1">
        <!-- Previous coaching -->
        <div class="f">
          <label class="f-label"
            >Previous Structured Coaching <span class="f-req">*</span></label
          >
          <p class="f-hint">
            Has the player received coaching outside of school or recreational
            leagues?
          </p>
          <div class="foot-row">
            {
              [
                { value: "yes", label: "Yes" },
                { value: "no", label: "No" },
              ].map(({ value, label }) => (
                <label class="rtile">
                  <input
                    type="radio"
                    name="previous_coaching"
                    value={value}
                    required
                  />
                  <span class="rtile-lbl">{label}</span>
                </label>
              ))
            }
          </div>
        </div>

        <!-- Injuries / physical notes -->
        <div class="f">
          <label class="f-label" for="injuries"
            >Injuries or Physical Considerations <span class="f-opt"
              >Recommended</span
            ></label
          >
          <p class="f-hint">
            Any current or recurring injuries, physical limitations, or medical
            notes our coaches should know about.
          </p>
          <textarea
            class="f-textarea"
            id="injuries"
            name="injuries"
            rows="3"
            placeholder="e.g. Recovering from a sprained ankle. No contact drills for 4 weeks..."
          ></textarea>
        </div>

        <!-- Player strengths -->
        <div class="f">
          <label class="f-label" for="player_strengths"
            >Player Strengths <span class="f-opt">Recommended</span></label
          >
          <p class="f-hint">What does this player do well on the pitch?</p>
          <textarea
            class="f-textarea"
            id="player_strengths"
            name="player_strengths"
            rows="3"
            placeholder="e.g. Strong in the air, good first touch, reads the game well under pressure..."
          ></textarea>
        </div>

        <!-- Areas to improve -->
        <div class="f">
          <label class="f-label" for="areas_to_improve"
            >Areas to Improve <span class="f-opt">Recommended</span></label
          >
          <p class="f-hint">
            Where does the player feel they need the most development?
          </p>
          <textarea
            class="f-textarea"
            id="areas_to_improve"
            name="areas_to_improve"
            rows="3"
            placeholder="e.g. Weak foot, defensive positioning, decision-making in tight spaces..."
          ></textarea>
        </div>
      </div>
    </div>

    <!-- ── 06 GOALS & AMBITIONS ───────────────── -->
    <div class="fsec">
      <div class="fsec-head">
        <span class="fsec-num">06</span>
        <div>
          <div class="fsec-label">Goals &amp; Ambitions</div>
          <div class="fsec-hint">Tell us where this player wants to go.</div>
        </div>
      </div>
      <div class="fgrid fgrid-1">
        <!-- Long-term ambition -->
        <div class="f">
          <label class="f-label" for="long_term_goal"
            >Long-term Football Ambition <span class="f-req">*</span></label
          >
          <select
            class="f-select"
            id="long_term_goal"
            name="long_term_goal"
            required
          >
            <option value="" disabled selected>Select an option</option>
            <option value="recreational"
              >Recreational — play for fun and fitness</option
            >
            <option value="local-competitive"
              >Local competitive — play at a strong club level</option
            >
            <option value="provincial"
              >Provincial — represent BC or compete provincially</option
            >
            <option value="national">National — national team pathway</option>
            <option value="professional"
              >Professional / semi-professional pathway</option
            >
          </select>
        </div>

        <!-- Development goals -->
        <div class="f">
          <label class="f-label" for="goals"
            >Development Goals <span class="f-opt">Recommended</span></label
          >
          <p class="f-hint">
            What does the player want to achieve in the next 6 – 12 months?
          </p>
          <textarea
            class="f-textarea"
            id="goals"
            name="goals"
            rows="4"
            placeholder="e.g. Earn a spot on a competitive U14 team by summer. Work on consistency when receiving under pressure..."
          ></textarea>
        </div>

        <!-- Referral -->
        <div class="f">
          <label class="f-label" for="referral"
            >How did you hear about us? <span class="f-opt">Optional</span
            ></label
          >
          <select class="f-select" id="referral" name="referral">
            <option value="" disabled selected>Select an option</option>
            <option value="instagram">Instagram</option>
            <option value="facebook">Facebook</option>
            <option value="google">Google Search</option>
            <option value="friend">Friend or Family</option>
            <option value="coach">Coach / Club</option>
            <option value="southvanfc_website">South Van FC Website</option>
            <option value="other">Other</option>
          </select>
        </div>
      </div>
    </div>
  </div><!-- /form-step[2] -->

  <!-- ── STEP 2 NAV ─────────────────────────── -->
  <div class="f-nav" id="step-nav-2" style="display:none">
    <button type="button" class="f-btn f-btn--ghost" id="back-btn">
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
      >
        <path d="M19 12H5M12 19l-7-7 7-7"></path>
      </svg>
      Back
    </button>
    <div class="f-note">
      <p class="caption">
        Fields marked <span class="f-req">*</span> are required.
      </p>
      <p class="caption">We respond within 48 hours.</p>
    </div>
    <button type="submit" class="f-btn" id="submit-btn">
      Submit Evaluation Request
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
      >
        <path d="M5 12h14M12 5l7 7-7 7"></path>
      </svg>
    </button>
  </div>
</form>

<style>
  /* ── Step indicator ── */
  .step-indicator {
    display: flex;
    align-items: center;
    margin-bottom: 32px;
    padding: 16px 0;
    border-bottom: 1px solid #eef0f7;
    position: sticky;
    top: 0;
    background: #fff;
    z-index: 10;
  }
  .step-pip {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }
  .step-circle {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 2px solid #d0d5e8;
    background: #fff;
    color: #6b7a9e;
    font-size: 14px;
    font-weight: 700;
    font-family: "Inter Variable", sans-serif;
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      background 0.25s,
      border-color 0.25s,
      color 0.25s;
  }
  .step-label {
    font-size: 11px;
    font-weight: 600;
    color: #6b7a9e;
    white-space: nowrap;
    transition: color 0.25s;
  }
  .step-connector {
    flex: 1;
    height: 2px;
    background: #d0d5e8;
    margin: 0 8px;
    margin-bottom: 22px;
    transition: background 0.25s;
  }
  .step-pip[data-active="true"] .step-circle {
    background: #e8b430;
    border-color: #e8b430;
    color: #011f4a;
  }
  .step-pip[data-active="true"] .step-label {
    color: #011f4a;
  }
  .step-pip[data-complete="true"] .step-circle {
    background: #011f4a;
    border-color: #011f4a;
    color: #fff;
  }
  .step-pip[data-complete="true"] .step-label {
    color: #011f4a;
  }
  .step-connector[data-complete="true"] {
    background: #011f4a;
  }

  /* ── Step containers ── */
  .form-step[data-step="2"] {
    display: none;
  }
  .form-step[data-step="2"].is-active {
    display: block;
  }

  /* ── Section blocks ── */
  .fsec {
    padding: 32px 0;
    border-bottom: 1px solid #eef0f7;
  }
  .fsec:last-of-type {
    border-bottom: none;
    padding-bottom: 0;
  }

  .fsec-head {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    margin-bottom: 26px;
  }
  .fsec-num {
    font-family: "Inter Variable", sans-serif;
    font-size: 40px;
    line-height: 1;
    color: #eef0f7;
    flex-shrink: 0;
    width: 40px;
    text-align: right;
    transition: color 0.3s;
  }
  .fsec:focus-within .fsec-num {
    color: #e8b430;
  }
  .fsec-label {
    font-family: "Inter Variable", sans-serif;
    font-size: 20px;
    letter-spacing: 1px;
    color: #011f4a;
    margin-bottom: 3px;
  }
  .fsec-hint {
    font-size: 12px;
    color: #6b7a9e;
  }

  /* ── Field grids ── */
  .fgrid {
    display: grid;
    gap: 18px;
    padding-left: 56px;
  }
  .fgrid-2 {
    grid-template-columns: 1fr 1fr;
  }
  .fgrid-1 {
    grid-template-columns: 1fr;
  }
  .f-full {
    grid-column: 1 / -1;
  }

  /* ── Fields ── */
  .f {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .f-label {
    font-size: 12px;
    font-weight: 700;
    color: #0a1428;
    display: flex;
    align-items: center;
    gap: 7px;
    flex-wrap: wrap;
  }
  .f-hint {
    font-size: 11px;
    color: #6b7a9e;
    margin-top: -2px;
  }
  .f-req {
    color: #e8b430;
    font-size: 13px;
  }
  .f-opt {
    font-size: 10px;
    font-weight: 400;
    color: #6b7a9e;
    background: #eef0f7;
    padding: 2px 8px;
    border-radius: 100px;
  }

  /* ── Inline validation errors ── */
  .f-err {
    display: none;
    font-size: 11px;
    color: #c0392b;
    font-weight: 600;
    margin-top: 1px;
  }
  .f-err.is-visible {
    display: block;
  }
  .f-input.is-invalid,
  .f-select.is-invalid {
    border-color: #c0392b;
    box-shadow: 0 0 0 3px rgba(192, 57, 43, 0.09);
  }

  /* ── Inputs ── */
  .f-input,
  .f-select,
  .f-textarea {
    font-family: "Inter Variable", system-ui, sans-serif;
    font-size: 14px;
    color: #0a1428;
    background: #fff;
    border: 1.5px solid #d0d5e8;
    border-radius: 8px;
    padding: 11px 13px;
    outline: none;
    transition:
      border-color 0.2s,
      box-shadow 0.2s;
    width: 100%;
    appearance: none;
    -webkit-appearance: none;
  }
  .f-input:focus,
  .f-select:focus,
  .f-textarea:focus {
    border-color: #013478;
    box-shadow: 0 0 0 3px rgba(1, 52, 120, 0.09);
  }
  .f-input::placeholder,
  .f-textarea::placeholder {
    color: #6b7a9e;
  }
  .f-input[type="date"] {
    cursor: pointer;
  }
  .f-select {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%236b7280' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e");
    background-position: right 11px center;
    background-repeat: no-repeat;
    background-size: 15px;
    padding-right: 34px;
    cursor: pointer;
  }
  .f-textarea {
    resize: vertical;
    min-height: 88px;
    line-height: 1.6;
  }

  /* ── Position tiles ── */
  .pos-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 8px;
    margin-top: 4px;
  }
  .pos-tile {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    padding: 13px 6px;
    border: 1.5px solid #d0d5e8;
    border-radius: 10px;
    cursor: pointer;
    background: #fff;
    transition:
      border-color 0.2s,
      background 0.2s;
    user-select: none;
  }
  .pos-tile:hover {
    border-color: #013478;
    background: #f7f8fc;
  }
  .pos-tile input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }
  .pos-tile:has(input:checked) {
    border-color: #013478;
    background: rgba(1, 52, 120, 0.04);
  }
  .pos-icon {
    font-size: 20px;
  }
  .pos-lbl {
    font-size: 10px;
    font-weight: 600;
    color: #3d4d6e;
    letter-spacing: 0.4px;
    text-align: center;
  }
  .pos-tile:has(input:checked) .pos-lbl {
    color: #013478;
  }
  .pos-check {
    position: absolute;
    top: 5px;
    right: 5px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #013478;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.2s;
  }
  .pos-tile:has(input:checked) .pos-check {
    opacity: 1;
  }

  /* ── Foot / yes-no radio tiles ── */
  .foot-row {
    display: flex;
    gap: 8px;
    margin-top: 4px;
  }
  .rtile {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    padding: 11px;
    border: 1.5px solid #d0d5e8;
    border-radius: 8px;
    cursor: pointer;
    background: #fff;
    transition:
      border-color 0.2s,
      background 0.2s;
    user-select: none;
  }
  .rtile:hover {
    border-color: #013478;
  }
  .rtile:has(input:checked) {
    border-color: #013478;
    background: rgba(1, 52, 120, 0.04);
  }
  .rtile input {
    accent-color: #013478;
    width: 15px;
    height: 15px;
    cursor: pointer;
  }
  .rtile-lbl {
    font-size: 13px;
    font-weight: 600;
    color: #3d4d6e;
  }
  .rtile:has(input:checked) .rtile-lbl {
    color: #013478;
  }

  /* ── Navigation strips ── */
  .f-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    padding-top: 28px;
    border-top: 2px solid #e8b430;
    margin-top: 6px;
  }
  .f-note {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: #6b7a9e;
    max-width: 520px;
  }
  .f-note svg {
    flex-shrink: 0;
    color: #013478;
  }
  .f-btn {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    background: #e8b430;
    color: #011f4a;
    font-family: "Inter Variable", system-ui, sans-serif;
    font-size: 14px;
    font-weight: 700;
    border: none;
    border-radius: 7px;
    padding: 14px 32px;
    cursor: pointer;
    transition:
      background 0.2s,
      transform 0.2s;
    flex-shrink: 0;
  }
  .f-btn:hover {
    background: #f5cc6a;
    transform: translateY(-2px);
  }
  .f-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }
  .f-btn--ghost {
    background: transparent;
    color: #011f4a;
    border: 1.5px solid #011f4a;
  }
  .f-btn--ghost:hover {
    background: #eef0f7;
    transform: translateY(-2px);
  }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .fgrid-2 {
      grid-template-columns: 1fr;
    }
    .fgrid {
      padding-left: 0;
    }
    .pos-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .f-nav {
      flex-direction: column;
      align-items: flex-start;
    }
  }
  @media (max-width: 500px) {
    .pos-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .foot-row {
      flex-wrap: wrap;
    }
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>

<script>
  const form = document.getElementById("eval-form") as HTMLFormElement | null;
  const nextBtn = document.getElementById(
    "next-btn",
  ) as HTMLButtonElement | null;
  const backBtn = document.getElementById(
    "back-btn",
  ) as HTMLButtonElement | null;
  const submitBtn = document.getElementById(
    "submit-btn",
  ) as HTMLButtonElement | null;

  if (!form || !nextBtn || !backBtn || !submitBtn)
    throw new Error("Eval form elements missing");

  const STEP1_REQUIRED: Array<{ id: string; type: string; msg: string }> = [
    { id: "full_name", type: "text", msg: "Player's full name is required." },
    { id: "dob", type: "text", msg: "Date of birth is required." },
    { id: "age_group", type: "select", msg: "Please select an age group." },
    {
      id: "years_playing",
      type: "select",
      msg: "Please select years playing.",
    },
    {
      id: "parent_name",
      type: "text",
      msg: "Parent or guardian name is required.",
    },
    {
      id: "parent_relationship",
      type: "select",
      msg: "Please select your relationship to the player.",
    },
    {
      id: "parent_email",
      type: "email",
      msg: "A valid email address is required.",
    },
    { id: "parent_phone", type: "text", msg: "A phone number is required." },
    {
      id: "positions",
      type: "checkbox",
      msg: "Please select at least one position.",
    },
    {
      id: "preferred_foot",
      type: "radio",
      msg: "Please select a dominant foot.",
    },
  ];

  function clearError(id: string) {
    const el = document.getElementById(id) as
      | HTMLInputElement
      | HTMLSelectElement
      | null;
    if (el) el.classList.remove("is-invalid");
    const errEl = document.getElementById(id + "-error");
    if (errEl) errEl.classList.remove("is-visible");
  }

  function validateStep1(): boolean {
    let ok = true;
    for (const { id, type, msg } of STEP1_REQUIRED) {
      let invalid = false;
      if (type === "checkbox") {
        invalid =
          form!.querySelectorAll('input[name="positions"]:checked').length ===
          0;
      } else if (type === "radio") {
        invalid =
          form!.querySelectorAll('input[name="preferred_foot"]:checked')
            .length === 0;
      } else if (type === "email") {
        const val = (
          (document.getElementById(id) as HTMLInputElement)?.value ?? ""
        ).trim();
        invalid = !val || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val);
      } else {
        invalid = !(
          (document.getElementById(id) as HTMLInputElement)?.value ?? ""
        ).trim();
      }
      const errEl = document.getElementById(id + "-error");
      const inputEl = document.getElementById(id) as
        | HTMLInputElement
        | HTMLSelectElement
        | null;
      if (invalid) {
        ok = false;
        if (errEl) {
          errEl.textContent = msg;
          errEl.classList.add("is-visible");
        }
        if (inputEl) inputEl.classList.add("is-invalid");
      } else {
        if (errEl) errEl.classList.remove("is-visible");
        if (inputEl) inputEl.classList.remove("is-invalid");
      }
    }
    return ok;
  }

  function goToStep(n: number) {
    const s1 = document.querySelector('[data-step="1"]') as HTMLElement | null;
    const s2 = document.querySelector('[data-step="2"]') as HTMLElement | null;
    const nav1 = document.getElementById("step-nav-1") as HTMLElement | null;
    const nav2 = document.getElementById("step-nav-2") as HTMLElement | null;
    const pip1 = document.querySelector('[data-pip="1"]') as HTMLElement | null;
    const pip2 = document.querySelector('[data-pip="2"]') as HTMLElement | null;
    const conn = document.querySelector(
      ".step-connector",
    ) as HTMLElement | null;

    if (n === 2) {
      if (s1) s1.style.display = "none";
      if (s2) s2.classList.add("is-active");
      if (nav1) nav1.style.display = "none";
      if (nav2) nav2.style.display = "flex";
      if (pip1) {
        pip1.setAttribute("data-active", "false");
        pip1.setAttribute("data-complete", "true");
      }
      if (pip2) pip2.setAttribute("data-active", "true");
      if (conn) conn.setAttribute("data-complete", "true");
    } else {
      if (s1) s1.style.display = "";
      if (s2) s2.classList.remove("is-active");
      if (nav1) nav1.style.display = "flex";
      if (nav2) nav2.style.display = "none";
      if (pip1) {
        pip1.setAttribute("data-active", "true");
        pip1.removeAttribute("data-complete");
      }
      if (pip2) pip2.removeAttribute("data-active");
      if (conn) conn.removeAttribute("data-complete");
    }

    document
      .getElementById("eval-form")
      ?.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  // Real-time error clearing on input
  for (const { id, type } of STEP1_REQUIRED) {
    if (type === "checkbox") {
      form
        .querySelectorAll('input[name="positions"]')
        .forEach((el) =>
          el.addEventListener("change", () => clearError("positions")),
        );
    } else if (type === "radio") {
      form
        .querySelectorAll('input[name="preferred_foot"]')
        .forEach((el) =>
          el.addEventListener("change", () => clearError("preferred_foot")),
        );
    } else {
      document
        .getElementById(id)
        ?.addEventListener("input", () => clearError(id));
    }
  }

  // Init — step 1 active
  document.querySelector('[data-pip="1"]')?.setAttribute("data-active", "true");

  nextBtn.addEventListener("click", () => {
    if (validateStep1()) goToStep(2);
  });
  backBtn.addEventListener("click", () => goToStep(1));

  // Submit loading state
  form.addEventListener("submit", () => {
    submitBtn!.disabled = true;
    submitBtn!.innerHTML = `
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
        stroke-linecap="round" style="animation:spin .7s linear infinite">
        <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
      </svg>
      Submitting...`;
  });
</script>
