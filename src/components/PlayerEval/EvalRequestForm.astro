---
// src/components/PlayerEval/EvalRequestForm.astro
// Field names match submit-evaluation.ts exactly.
// Sections: Player Details | Playing Profile | Parent/Guardian | Player Background | Goals & Referral
// Google Sheet columns (in order):
// Timestamp | Full Name | DOB | Age Group | Current Club | Years Playing | School Grade |
// Positions | Dominant Foot | Weekly Training Hours | Competition Level | Other Sports |
// Parent Name | Parent Relationship | Parent Email | Parent Phone |
// Previous Coaching | Injuries / Physical Notes | Player Strengths | Areas to Improve |
// Response to Feedback | Motivation Drive | Handles Mistakes |
// Long-term Ambition | Development Goals | Referral Source
---

<!-- Honeypot — hidden from users, catches bots -->
<input
  type="text"
  name="company"
  autocomplete="off"
  tabindex="-1"
  aria-hidden="true"
  style="position:absolute;left:-9999px;opacity:0;pointer-events:none;"
/>

<form action="/api/submit-evaluation" method="POST" id="eval-form">
  <!-- ── 01 PLAYER DETAILS ───────────────────── -->
  <div class="fsec">
    <div class="fsec-head">
      <span class="fsec-num">01</span>
      <div>
        <div class="fsec-label">Player Details</div>
        <div class="fsec-hint">
          Basic information about the player being evaluated.
        </div>
      </div>
    </div>
    <div class="fgrid fgrid-2">
      <div class="f">
        <label class="f-label" for="full_name"
          >Full Name <span class="f-req">*</span></label
        >
        <input
          class="f-input"
          id="full_name"
          name="full_name"
          type="text"
          placeholder="Player's full name"
          required
        />
      </div>
      <div class="f">
        <label class="f-label" for="dob"
          >Date of Birth <span class="f-req">*</span></label
        >
        <input class="f-input" id="dob" name="dob" type="date" required />
      </div>
      <div class="f">
        <label class="f-label" for="age_group"
          >Age Group <span class="f-req">*</span></label
        >
        <select class="f-select" id="age_group" name="age_group" required>
          <option value="" disabled selected>Select age group</option>
          <option value="u6-u8">U6 – U8</option>
          <option value="u8-u11">U8 – U11</option>
          <option value="u11-u15">U11 – U15</option>
          <option value="u15-u18">U15 – U18</option>
        </select>
      </div>
      <div class="f">
        <label class="f-label" for="club"
          >Current Club <span class="f-opt">Optional</span></label
        >
        <input
          class="f-input"
          id="club"
          name="club"
          type="text"
          placeholder="Leave blank if no club"
        />
      </div>
      <div class="f">
        <label class="f-label" for="years_playing"
          >Years Playing Soccer <span class="f-req">*</span></label
        >
        <select
          class="f-select"
          id="years_playing"
          name="years_playing"
          required
        >
          <option value="" disabled selected>Select range</option>
          <option value="less-than-1">Less than 1 year</option>
          <option value="1-2">1 – 2 years</option>
          <option value="3-5">3 – 5 years</option>
          <option value="6-9">6 – 9 years</option>
          <option value="10+">10+ years</option>
        </select>
      </div>
      <div class="f">
        <label class="f-label" for="school_grade"
          >School Grade <span class="f-opt">Optional</span></label
        >
        <select class="f-select" id="school_grade" name="school_grade">
          <option value="" disabled selected>Select grade</option>
          <option value="k">Kindergarten</option>
          <option value="1">Grade 1</option>
          <option value="2">Grade 2</option>
          <option value="3">Grade 3</option>
          <option value="4">Grade 4</option>
          <option value="5">Grade 5</option>
          <option value="6">Grade 6</option>
          <option value="7">Grade 7</option>
          <option value="8">Grade 8</option>
          <option value="9">Grade 9</option>
          <option value="10">Grade 10</option>
          <option value="11">Grade 11</option>
          <option value="12">Grade 12</option>
        </select>
      </div>
    </div>
  </div>

  <!-- ── 02 PLAYING PROFILE ─────────────────── -->
  <div class="fsec">
    <div class="fsec-head">
      <span class="fsec-num">02</span>
      <div>
        <div class="fsec-label">Playing Profile</div>
        <div class="fsec-hint">
          Positions, technical details, and current training load.
        </div>
      </div>
    </div>
    <div class="fgrid fgrid-1">
      <!-- Position tiles -->
      <div class="f">
        <label class="f-label"
          >Primary Position(s) <span class="f-req">*</span></label
        >
        <p class="f-hint">Select all that apply.</p>
        <div class="pos-grid">
          {
            [
              { value: "GK", label: "Goalkeeper", icon: "🧤" },
              { value: "Defender", label: "Defender", icon: "🛡️" },
              { value: "Midfielder", label: "Midfielder", icon: "⚙️" },
              { value: "Winger", label: "Winger", icon: "⚡" },
              { value: "Striker", label: "Striker", icon: "⚽" },
            ].map(({ value, label, icon }) => (
              <label class="pos-tile">
                <input type="checkbox" name="positions" value={value} />
                <span class="pos-icon">{icon}</span>
                <span class="pos-lbl">{label}</span>
                <span class="pos-check">
                  <svg
                    width="10"
                    height="10"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="3.5"
                    stroke-linecap="round"
                  >
                    <path d="M20 6L9 17l-5-5" />
                  </svg>
                </span>
              </label>
            ))
          }
        </div>
      </div>

      <!-- Dominant foot -->
      <div class="f">
        <label class="f-label">Dominant Foot <span class="f-req">*</span></label
        >
        <div class="foot-row">
          {
            [
              { value: "right", label: "Right" },
              { value: "left", label: "Left" },
              { value: "both", label: "Both" },
            ].map(({ value, label }) => (
              <label class="rtile">
                <input
                  type="radio"
                  name="preferred_foot"
                  value={value}
                  required
                />
                <span class="rtile-lbl">{label}</span>
              </label>
            ))
          }
        </div>
      </div>

      <!-- Weekly training hours -->
      <div class="f">
        <label class="f-label" for="training_hours"
          >Weekly Training Hours <span class="f-req">*</span></label
        >
        <p class="f-hint">
          Outside of school PE — include all club sessions, personal training,
          and pickup.
        </p>
        <select
          class="f-select"
          id="training_hours"
          name="training_hours"
          required
        >
          <option value="" disabled selected>Select range</option>
          <option value="less-than-2">Less than 2 hours</option>
          <option value="2-4">2 – 4 hours</option>
          <option value="4-6">4 – 6 hours</option>
          <option value="6-8">6 – 8 hours</option>
          <option value="8+">8+ hours</option>
        </select>
      </div>

      <!-- Competition level -->
      <div class="f">
        <label class="f-label" for="competition_level"
          >Current Competition Level <span class="f-req">*</span></label
        >
        <p class="f-hint">
          Select the highest level this player currently competes at in
          Vancouver / Lower Mainland.
        </p>
        <select
          class="f-select"
          id="competition_level"
          name="competition_level"
          required
        >
          <option value="" disabled selected>Select level</option>
          <option value="bcspl">BCSPL (BC Soccer Premier League)</option>
          <option value="metro">Metro</option>
          <option value="gold">Gold</option>
          <option value="silver">Silver</option>
          <option value="bronze">Bronze</option>
          <option value="recreational">Recreational / House League</option>
          <option value="school-only">School team only</option>
          <option value="no-team">Not currently on a team</option>
        </select>
      </div>

      <!-- Other sports -->
      <div class="f">
        <label class="f-label" for="other_sports"
          >Other Sports Currently Played <span class="f-opt">Optional</span
          ></label
        >
        <p class="f-hint">
          List any other sports the player actively trains or competes in.
        </p>
        <input
          class="f-input"
          id="other_sports"
          name="other_sports"
          type="text"
          placeholder="e.g. Basketball, ice hockey, swimming"
        />
      </div>
    </div>
  </div>

  <!-- ── 03 PARENT / GUARDIAN ───────────────── -->
  <div class="fsec">
    <div class="fsec-head">
      <span class="fsec-num">03</span>
      <div>
        <div class="fsec-label">Parent / Guardian</div>
        <div class="fsec-hint">
          Required for all players under 18. This is our primary contact for
          scheduling and updates.
        </div>
      </div>
    </div>
    <div class="fgrid fgrid-2">
      <div class="f">
        <label class="f-label" for="parent_name"
          >Full Name <span class="f-req">*</span></label
        >
        <input
          class="f-input"
          id="parent_name"
          name="parent_name"
          type="text"
          placeholder="Parent or guardian full name"
          required
        />
      </div>
      <div class="f">
        <label class="f-label" for="parent_relationship"
          >Relationship to Player <span class="f-req">*</span></label
        >
        <select
          class="f-select"
          id="parent_relationship"
          name="parent_relationship"
          required
        >
          <option value="" disabled selected>Select relationship</option>
          <option value="mother">Mother</option>
          <option value="father">Father</option>
          <option value="guardian">Legal Guardian</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div class="f">
        <label class="f-label" for="parent_email"
          >Email Address <span class="f-req">*</span></label
        >
        <input
          class="f-input"
          id="parent_email"
          name="parent_email"
          type="email"
          placeholder="parent@email.com"
          required
        />
      </div>
      <div class="f">
        <label class="f-label" for="parent_phone"
          >Phone Number <span class="f-req">*</span></label
        >
        <input
          class="f-input"
          id="parent_phone"
          name="parent_phone"
          type="tel"
          placeholder="+1 (604) 000-0000"
          required
        />
      </div>
    </div>
  </div>

  <!-- ── 04 PLAYER BACKGROUND ──────────────── -->
  <div class="fsec">
    <div class="fsec-head">
      <span class="fsec-num">04</span>
      <div>
        <div class="fsec-label">Player Background</div>
        <div class="fsec-hint">
          Helps us tailor every session to where the player is right now.
        </div>
      </div>
    </div>
    <div class="fgrid fgrid-1">
      <!-- Previous coaching -->
      <div class="f">
        <label class="f-label"
          >Previous Structured Coaching <span class="f-req">*</span></label
        >
        <p class="f-hint">
          Has the player received coaching outside of school or recreational
          leagues?
        </p>
        <div class="foot-row">
          {
            [
              { value: "yes", label: "Yes" },
              { value: "no", label: "No" },
            ].map(({ value, label }) => (
              <label class="rtile">
                <input
                  type="radio"
                  name="previous_coaching"
                  value={value}
                  required
                />
                <span class="rtile-lbl">{label}</span>
              </label>
            ))
          }
        </div>
      </div>

      <!-- Injuries / physical notes -->
      <div class="f">
        <label class="f-label" for="injuries"
          >Injuries or Physical Considerations <span class="f-opt"
            >Recommended</span
          ></label
        >
        <p class="f-hint">
          Any current or recurring injuries, physical limitations, or medical
          notes our coaches should know about.
        </p>
        <textarea
          class="f-textarea"
          id="injuries"
          name="injuries"
          rows="3"
          placeholder="e.g. Recovering from a sprained ankle. No contact drills for 4 weeks..."
        ></textarea>
      </div>

      <!-- Player strengths -->
      <div class="f">
        <label class="f-label" for="player_strengths"
          >Player Strengths <span class="f-opt">Recommended</span></label
        >
        <p class="f-hint">What does this player do well on the pitch?</p>
        <textarea
          class="f-textarea"
          id="player_strengths"
          name="player_strengths"
          rows="3"
          placeholder="e.g. Strong in the air, good first touch, reads the game well under pressure..."
        ></textarea>
      </div>

      <!-- Areas to improve -->
      <div class="f">
        <label class="f-label" for="areas_to_improve"
          >Areas to Improve <span class="f-opt">Recommended</span></label
        >
        <p class="f-hint">
          Where does the player feel they need the most development?
        </p>
        <textarea
          class="f-textarea"
          id="areas_to_improve"
          name="areas_to_improve"
          rows="3"
          placeholder="e.g. Weak foot, defensive positioning, decision-making in tight spaces..."
        ></textarea>
      </div>

      <!-- Response to feedback -->
      <div class="f">
        <label class="f-label" for="response_to_feedback"
          >Response to Coaching Feedback <span class="f-req">*</span></label
        >
        <p class="f-hint">
          How does this player typically respond when a coach corrects them
          during training?
        </p>
        <select
          class="f-select"
          id="response_to_feedback"
          name="response_to_feedback"
          required
        >
          <option value="" disabled selected>Select an option</option>
          <option value="adjusts-immediately"
            >Adjusts immediately and tries again</option
          >
          <option value="needs-moment"
            >Takes a moment to process, then responds positively</option
          >
          <option value="sometimes-pushback"
            >Sometimes questions or pushes back</option
          >
          <option value="gets-frustrated"
            >Tends to get frustrated or withdraw</option
          >
        </select>
      </div>

      <!-- Motivation / drive -->
      <div class="f">
        <label class="f-label" for="motivation_drive"
          >Motivation to Improve <span class="f-req">*</span></label
        >
        <p class="f-hint">What best describes what drives this player?</p>
        <select
          class="f-select"
          id="motivation_drive"
          name="motivation_drive"
          required
        >
          <option value="" disabled selected>Select an option</option>
          <option value="self-driven"
            >Highly self-motivated — pushes themselves without prompting</option
          >
          <option value="coach-driven"
            >Responds well when challenged by coaches</option
          >
          <option value="competition-driven"
            >Motivated by games and competition</option
          >
          <option value="needs-encouragement"
            >Needs consistent encouragement to stay focused</option
          >
        </select>
      </div>

      <!-- Handles mistakes -->
      <div class="f">
        <label class="f-label" for="handles_mistakes"
          >Handling Mistakes <span class="f-req">*</span></label
        >
        <p class="f-hint">
          How does this player typically respond to making mistakes in training
          or games?
        </p>
        <select
          class="f-select"
          id="handles_mistakes"
          name="handles_mistakes"
          required
        >
          <option value="" disabled selected>Select an option</option>
          <option value="bounces-back"
            >Bounces back quickly and refocuses</option
          >
          <option value="brief-frustration"
            >Brief frustration, then moves on</option
          >
          <option value="lingers">Lingers on mistakes and loses focus</option>
          <option value="shuts-down"
            >Shuts down or becomes visibly upset</option
          >
        </select>
      </div>
    </div>
  </div>

  <!-- ── 05 GOALS & REFERRAL ────────────────── -->
  <div class="fsec">
    <div class="fsec-head">
      <span class="fsec-num">05</span>
      <div>
        <div class="fsec-label">Goals &amp; Ambitions</div>
        <div class="fsec-hint">Tell us where this player wants to go.</div>
      </div>
    </div>
    <div class="fgrid fgrid-1">
      <!-- Long-term ambition -->
      <div class="f">
        <label class="f-label" for="long_term_goal"
          >Long-term Football Ambition <span class="f-req">*</span></label
        >
        <select
          class="f-select"
          id="long_term_goal"
          name="long_term_goal"
          required
        >
          <option value="" disabled selected>Select an option</option>
          <option value="recreational"
            >Recreational — play for fun and fitness</option
          >
          <option value="local-competitive"
            >Local competitive — play at a strong club level</option
          >
          <option value="provincial"
            >Provincial — represent BC or compete provincially</option
          >
          <option value="national">National — national team pathway</option>
          <option value="professional"
            >Professional / semi-professional pathway</option
          >
        </select>
      </div>

      <!-- Development goals -->
      <div class="f">
        <label class="f-label" for="goals"
          >Development Goals <span class="f-opt">Recommended</span></label
        >
        <p class="f-hint">
          What does the player want to achieve in the next 6 – 12 months?
        </p>
        <textarea
          class="f-textarea"
          id="goals"
          name="goals"
          rows="4"
          placeholder="e.g. Earn a spot on a competitive U14 team by summer. Work on consistency when receiving under pressure..."
        ></textarea>
      </div>

      <!-- Referral -->
      <div class="f">
        <label class="f-label" for="referral"
          >How did you hear about us? <span class="f-opt">Optional</span></label
        >
        <select class="f-select" id="referral" name="referral">
          <option value="" disabled selected>Select an option</option>
          <option value="instagram">Instagram</option>
          <option value="facebook">Facebook</option>
          <option value="google">Google Search</option>
          <option value="friend">Friend or Family</option>
          <option value="coach">Coach / Club</option>
          <option value="southvanfc_website">South Van FC Website</option>
          <option value="other">Other</option>
        </select>
      </div>
    </div>
  </div>

  <!-- ── SUBMIT ─────────────────────────────── -->
  <div class="f-submit">
    <div class="f-note">
      <p class="caption">
        Fields marked <span class="f-req">*</span> are required.
      </p>
      <p class="caption">We respond within 48 hours.</p>
    </div>
    <button type="submit" class="f-btn" id="submit-btn">
      Submit Evaluation Request
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
      >
        <path d="M5 12h14M12 5l7 7-7 7"></path>
      </svg>
    </button>
  </div>
</form>

<style>
  /* ── Section blocks ── */
  .fsec {
    padding: 32px 0;
    border-bottom: 1px solid #eef0f7;
  }
  .fsec:last-of-type {
    border-bottom: none;
    padding-bottom: 0;
  }

  .fsec-head {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    margin-bottom: 26px;
  }
  .fsec-num {
    font-family: "Inter Variable", sans-serif;
    font-size: 40px;
    line-height: 1;
    color: #eef0f7;
    flex-shrink: 0;
    width: 40px;
    text-align: right;
    transition: color 0.3s;
  }
  .fsec:focus-within .fsec-num {
    color: #e8b430;
  }
  .fsec-label {
    font-family: "Inter Variable", sans-serif;
    font-size: 20px;
    letter-spacing: 1px;
    color: #011f4a;
    margin-bottom: 3px;
  }
  .fsec-hint {
    font-size: 12px;
    color: #6b7a9e;
  }

  /* ── Field grids ── */
  .fgrid {
    display: grid;
    gap: 18px;
    padding-left: 56px;
  }
  .fgrid-2 {
    grid-template-columns: 1fr 1fr;
  }
  .fgrid-1 {
    grid-template-columns: 1fr;
  }
  .f-full {
    grid-column: 1 / -1;
  }

  /* ── Fields ── */
  .f {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .f-label {
    font-size: 12px;
    font-weight: 700;
    color: #0a1428;
    display: flex;
    align-items: center;
    gap: 7px;
    flex-wrap: wrap;
  }
  .f-hint {
    font-size: 11px;
    color: #6b7a9e;
    margin-top: -2px;
  }
  .f-req {
    color: #e8b430;
    font-size: 13px;
  }
  .f-opt {
    font-size: 10px;
    font-weight: 400;
    color: #6b7a9e;
    background: #eef0f7;
    padding: 2px 8px;
    border-radius: 100px;
  }

  /* ── Inputs ── */
  .f-input,
  .f-select,
  .f-textarea {
    font-family: "Inter Variable", system-ui, sans-serif;
    font-size: 14px;
    color: #0a1428;
    background: #fff;
    border: 1.5px solid #d0d5e8;
    border-radius: 8px;
    padding: 11px 13px;
    outline: none;
    transition:
      border-color 0.2s,
      box-shadow 0.2s;
    width: 100%;
    appearance: none;
    -webkit-appearance: none;
  }
  .f-input:focus,
  .f-select:focus,
  .f-textarea:focus {
    border-color: #013478;
    box-shadow: 0 0 0 3px rgba(1, 52, 120, 0.09);
  }
  .f-input::placeholder,
  .f-textarea::placeholder {
    color: #6b7a9e;
  }
  .f-input[type="date"] {
    cursor: pointer;
  }
  .f-select {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%236b7280' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e");
    background-position: right 11px center;
    background-repeat: no-repeat;
    background-size: 15px;
    padding-right: 34px;
    cursor: pointer;
  }
  .f-textarea {
    resize: vertical;
    min-height: 88px;
    line-height: 1.6;
  }

  /* ── Position tiles ── */
  .pos-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 8px;
    margin-top: 4px;
  }
  .pos-tile {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    padding: 13px 6px;
    border: 1.5px solid #d0d5e8;
    border-radius: 10px;
    cursor: pointer;
    background: #fff;
    transition:
      border-color 0.2s,
      background 0.2s;
    user-select: none;
  }
  .pos-tile:hover {
    border-color: #013478;
    background: #f7f8fc;
  }
  .pos-tile input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }
  .pos-tile:has(input:checked) {
    border-color: #013478;
    background: rgba(1, 52, 120, 0.04);
  }
  .pos-icon {
    font-size: 20px;
  }
  .pos-lbl {
    font-size: 10px;
    font-weight: 600;
    color: #3d4d6e;
    letter-spacing: 0.4px;
    text-align: center;
  }
  .pos-tile:has(input:checked) .pos-lbl {
    color: #013478;
  }
  .pos-check {
    position: absolute;
    top: 5px;
    right: 5px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #013478;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.2s;
  }
  .pos-tile:has(input:checked) .pos-check {
    opacity: 1;
  }

  /* ── Foot / yes-no radio tiles ── */
  .foot-row {
    display: flex;
    gap: 8px;
    margin-top: 4px;
  }
  .rtile {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    padding: 11px;
    border: 1.5px solid #d0d5e8;
    border-radius: 8px;
    cursor: pointer;
    background: #fff;
    transition:
      border-color 0.2s,
      background 0.2s;
    user-select: none;
  }
  .rtile:hover {
    border-color: #013478;
  }
  .rtile:has(input:checked) {
    border-color: #013478;
    background: rgba(1, 52, 120, 0.04);
  }
  .rtile input {
    accent-color: #013478;
    width: 15px;
    height: 15px;
    cursor: pointer;
  }
  .rtile-lbl {
    font-size: 13px;
    font-weight: 600;
    color: #3d4d6e;
  }
  .rtile:has(input:checked) .rtile-lbl {
    color: #013478;
  }

  /* ── Submit strip ── */
  .f-submit {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    padding-top: 28px;
    border-top: 2px solid #e8b430;
    margin-top: 6px;
  }
  .f-note {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: #6b7a9e;
    max-width: 520px;
  }
  .f-note svg {
    flex-shrink: 0;
    color: #013478;
  }
  .f-btn {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    background: #e8b430;
    color: #011f4a;
    font-family: "Inter Variable", system-ui, sans-serif;
    font-size: 14px;
    font-weight: 700;
    border: none;
    border-radius: 7px;
    padding: 14px 32px;
    cursor: pointer;
    transition:
      background 0.2s,
      transform 0.2s;
    flex-shrink: 0;
  }
  .f-btn:hover {
    background: #f5cc6a;
    transform: translateY(-2px);
  }
  .f-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .fgrid-2 {
      grid-template-columns: 1fr;
    }
    .fgrid {
      padding-left: 0;
    }
    .pos-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .f-submit {
      flex-direction: column;
      align-items: flex-start;
    }
  }
  @media (max-width: 500px) {
    .pos-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .foot-row {
      flex-wrap: wrap;
    }
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>

<script>
  // Submitting state feedback
  const form = document.getElementById("eval-form") as HTMLFormElement | null;
  const btn = document.getElementById("submit-btn") as HTMLButtonElement | null;
  if (form && btn) {
    form.addEventListener("submit", () => {
      btn.disabled = true;
      btn.innerHTML = `
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
          stroke-linecap="round" style="animation:spin .7s linear infinite">
          <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
        </svg>
        Submitting...`;
    });
  }
</script>
