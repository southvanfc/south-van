---
import type { CTALink } from "../types/types";

// src/components/CTABand.astro

interface Props {
  title: string;
  body: string;
  links: CTALink[];
}

const { title, body, links } = Astro.props;
---

<div class="cta-band">
  <div>
    <h2 class="cta-title" set:html={title} />
    <p class="section-body">{body}</p>
  </div>

  <div class="cta-actions">
    {
      links.map(({ href, label, style }: CTALink) => (
        <a href={href} class:list={["btn", `btn-${style}`]}>
          {label}
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
          >
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
      ))
    }
  </div>
</div>

<style>
  .cta-band {
    background: var(--off-white);
    border-top: 3px solid var(--gold);
    padding: 72px 80px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
    flex-wrap: wrap;
  }

  .cta-title {
    font-family: "Inter Variable", sans-serif;
    font-size: clamp(36px, 4vw, 58px);
    line-height: 0.92;
    letter-spacing: 1px;
    color: var(--navy-dark);
    margin-bottom: 12px;
  }

  .cta-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  @media (max-width: 960px) {
    .cta-band {
      flex-direction: column;
      align-items: flex-start;
      padding: 56px 28px;
    }
  }
</style>
