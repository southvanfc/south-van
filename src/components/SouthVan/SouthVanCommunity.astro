---
// src/components/SouthVan/SouthVanCommunity.astro

const pillars = [
  {
    icon: "🏘️",
    name: "A Neighbourhood Club",
    description:
      "South Van FC is not a franchise or a multi-location brand. We are one club, in one part of the city, built by people who live and play here.",
  },
  {
    icon: "🔗",
    name: "Youth to Men's Pathway",
    description:
      "Players who come up through the Academy have a clear path to the Men's Team. The club was designed with this progression in mind from day one.",
  },
  {
    icon: "📋",
    name: "Individual Development Plans",
    description:
      "Every academy player gets a personal IDP. We track technical progress, set targets, and use video analysis to give every player the attention they deserve.",
  },
  {
    icon: "🤝",
    name: "Accessible to the Community",
    description:
      "We believe quality football development should be available to families in South Vancouver, not just those who can travel to expensive centralized programs.",
  },
];
---

<section class="svc">
  <div class="svc-header">
    <span class="eyebrow eyebrow-navy">What Makes Us Different</span>
    <h2 class="section-title">Built for South Van</h2>
  </div>

  <div class="svc-grid">
    {
      pillars.map(({ icon, name, description }) => (
        <div class="svc-card">
          <div class="svc-icon">{icon}</div>
          <h3 class="svc-name">{name}</h3>
          <p class="svc-desc">{description}</p>
        </div>
      ))
    }
  </div>
</section>

<style>
  .svc {
    background: var(--off-white);
    padding: 96px 80px;
  }

  .svc-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .svc-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    background: var(--lt-gray);
  }

  .svc-card {
    background: #fff;
    padding: 40px 32px;
    border-top: 3px solid transparent;
    transition:
      border-color 0.3s,
      transform 0.3s;
    cursor: default;
  }
  .svc-card:hover {
    border-top-color: var(--gold);
    transform: translateY(-4px);
  }

  .svc-icon {
    width: 44px;
    height: 44px;
    background: var(--navy);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    margin-bottom: 18px;
  }

  .svc-name {
    font-family: "Inter Variable", sans-serif;
    font-size: 18px;
    letter-spacing: 0.5px;
    color: var(--navy-dark);
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .svc-desc {
    font-size: 14px;
    line-height: 1.65;
    color: var(--text-light);
  }

  @media (max-width: 960px) {
    .svc {
      padding: 64px 28px;
    }
    .svc-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .svc-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
