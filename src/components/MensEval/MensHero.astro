---
// src/components/mens/MensHero.astro
---

<section class="mens-hero">
  <div class="field-pattern" aria-hidden="true"></div>

  <!-- Bold accent bar top-left -->
  <div class="accent-bar" aria-hidden="true"></div>

  <div class="hero-inner">
    <div class="hero-left">
      <nav class="crumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <svg
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"><path d="M9 18l6-6-6-6"></path></svg
        >
        <span class="crumb-cur">Men's Squad Application</span>
      </nav>
      <span class="eyebrow">Men's Training Squad</span>
      <h1 class="hero-title">
        Earn<br />
        Your<br />
        <em>Place.</em>
      </h1>
    </div>

    <div class="hero-right">
      <p class="hero-body">
        South Van FC runs on competition. Every spot on the squad is earned, not
        given. We're looking for players who train hard, show up consistently,
        and push the standard of everyone around them. If that's you, start
        here.
      </p>

      <div class="hero-stats">
        <div class="hstat">
          <div class="hstat-val">VMSL</div>
          <div class="hstat-lbl">League</div>
        </div>
        <div class="hstat-divider" aria-hidden="true"></div>
        <div class="hstat">
          <div class="hstat-val">Weekly</div>
          <div class="hstat-lbl">Training</div>
        </div>
        <div class="hstat-divider" aria-hidden="true"></div>
        <div class="hstat">
          <div class="hstat-val">Merit</div>
          <div class="hstat-lbl">Based Selection</div>
        </div>
      </div>

      <div class="hero-tags">
        <span class="tag">High Standards</span>
        <span class="tag">Full Season Commitment</span>
        <span class="tag">Performance-Based Minutes</span>
      </div>
    </div>
  </div>

  <div class="hero-stripe" aria-hidden="true"></div>
</section>

<style>
  .mens-hero {
    background: #011f4a;
    padding: 72px 80px 0;
    position: relative;
    overflow: hidden;
  }

  .field-pattern {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 59px,
        rgba(255, 255, 255, 0.02) 59px,
        rgba(255, 255, 255, 0.02) 60px
      ),
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 59px,
        rgba(255, 255, 255, 0.02) 59px,
        rgba(255, 255, 255, 0.02) 60px
      );
  }

  /* Gold vertical accent on left edge */
  .accent-bar {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: linear-gradient(180deg, #e8b430 0%, rgba(232, 180, 48, 0) 100%);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 80px;
    align-items: end;
    position: relative;
    z-index: 2;
    padding-bottom: 64px;
  }

  /* Breadcrumb */
  .crumb {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.35);
    margin-bottom: 24px;
  }
  .crumb a {
    color: rgba(255, 255, 255, 0.35);
    text-decoration: none;
    transition: color 0.2s;
  }
  .crumb a:hover {
    color: rgba(255, 255, 255, 0.65);
  }
  .crumb-cur {
    color: #e8b430;
  }

  .eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    display: block;
    color: #e8b430;
    margin-bottom: 16px;
  }

  /* Big stacked title — each line own row for maximum impact */
  .hero-title {
    font-family: "Bebas Neue", sans-serif;
    font-size: clamp(72px, 8vw, 120px);
    line-height: 0.88;
    letter-spacing: 3px;
    color: rgba(255, 255, 255, 0.18);
    white-space: nowrap;
  }
  .hero-title em {
    font-style: normal;
    color: #e8b430;
    display: block;
    -webkit-text-stroke: 1px #e8b430;
  }

  /* Right col */
  .hero-right {
    display: flex;
    flex-direction: column;
    gap: 28px;
    padding-bottom: 8px;
  }

  .hero-body {
    font-size: 16px;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.55);
    max-width: 480px;
    border-left: 2px solid rgba(232, 180, 48, 0.4);
    padding-left: 20px;
  }

  /* Stats row */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 0;
  }
  .hstat {
    padding: 0 28px;
    text-align: center;
  }
  .hstat:first-child {
    padding-left: 0;
  }
  .hstat-val {
    font-family: "Bebas Neue", sans-serif;
    font-size: 28px;
    letter-spacing: 1.5px;
    color: #fff;
    line-height: 1;
    margin-bottom: 4px;
  }
  .hstat-lbl {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
  }
  .hstat-divider {
    width: 1px;
    height: 36px;
    background: rgba(255, 255, 255, 0.1);
    flex-shrink: 0;
  }

  /* Tags */
  .hero-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .tag {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.5px;
    padding: 5px 13px;
    border-radius: 4px;
    background: rgba(232, 180, 48, 0.1);
    border: 1px solid rgba(232, 180, 48, 0.25);
    color: rgba(232, 180, 48, 0.85);
  }

  /* Gold stripe */
  .hero-stripe {
    height: 6px;
    background: repeating-linear-gradient(
      90deg,
      #e8b430 0,
      #e8b430 40px,
      transparent 40px,
      transparent 48px
    );
    position: relative;
    z-index: 2;
  }

  @media (max-width: 960px) {
    .mens-hero {
      padding: 60px 28px 0;
    }
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 32px;
      padding-bottom: 52px;
    }
    .hero-title {
      font-size: clamp(64px, 14vw, 96px);
    }
    .hero-stats {
      flex-wrap: wrap;
      gap: 20px;
    }
    .hstat-divider {
      display: none;
    }
    .hstat {
      padding: 0;
      text-align: left;
    }
    .hero-body {
      font-size: 15px;
    }
  }
</style>
