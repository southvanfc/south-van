---
// src/components/home/Hero.astro

const { bannerImage } = Astro.props;
---

<section class="hero">
  <!-- Left: Copy -->
  <div class="hero-left">
    <span class="eyebrow eyebrow-gold fu d1">Vancouver Football Club</span>

    <h1 class="hero-title fu d2">
      South
      <em>Van FC</em>
    </h1>

    <p class="hero-sub fu d3">
      A youth soccer club developing players from U8 to U18 in South Vancouver.
      We also run a competitive men's side in the VMSL.
    </p>

    <div class="hero-cta-block fu d4">
      <p class="hero-cta-label">Who are you here for?</p>
      <div class="hero-actions">
        <a href="/academy/" class="btn btn-gold">
          <span class="btn-main">Youth Academy</span>
          <span class="btn-sub">Ages U8–U18</span>
        </a>
        <a href="/mens-team/" class="btn btn-outline-white">
          <span class="btn-main">Men's Team</span>
          <span class="btn-sub">Adult · VMSL</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Right: Floating crest -->
  <div class="hero-right">
    <div class="field-pattern"></div>
    <svg
      class="pitch-markings"
      viewBox="0 0 500 500"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <!-- Halfway line -->
      <line
        x1="0"
        y1="250"
        x2="500"
        y2="250"
        stroke="rgba(255,255,255,0.07)"
        stroke-width="1.5"></line>
      <!-- Center circle -->
      <circle
        cx="250"
        cy="250"
        r="150"
        fill="none"
        stroke="rgba(255,255,255,0.07)"
        stroke-width="1.5"></circle>
      <!-- Center spot -->
      <circle cx="250" cy="250" r="5" fill="rgba(255,255,255,0.12)"></circle>
      <!-- Penalty arc top -->
      <path
        d="M 170 0 A 95 95 0 0 1 330 0"
        fill="none"
        stroke="rgba(255,255,255,0.05)"
        stroke-width="1.5"></path>
      <!-- Penalty arc bottom -->
      <path
        d="M 170 500 A 95 95 0 0 0 330 500"
        fill="none"
        stroke="rgba(255,255,255,0.05)"
        stroke-width="1.5"></path>
      <!-- Goal box top -->
      <rect
        x="170"
        y="0"
        width="160"
        height="55"
        fill="none"
        stroke="rgba(255,255,255,0.05)"
        stroke-width="1.5"></rect>
      <!-- Goal box bottom -->
      <rect
        x="170"
        y="445"
        width="160"
        height="55"
        fill="none"
        stroke="rgba(255,255,255,0.05)"
        stroke-width="1.5"></rect>
      <!-- Corner arcs -->
      <path
        d="M 0 20 A 20 20 0 0 0 20 0"
        fill="none"
        stroke="rgba(255,255,255,0.05)"
        stroke-width="1.5"></path>
      <path
        d="M 480 0 A 20 20 0 0 0 500 20"
        fill="none"
        stroke="rgba(255,255,255,0.05)"
        stroke-width="1.5"></path>
      <path
        d="M 0 480 A 20 20 0 0 1 20 500"
        fill="none"
        stroke="rgba(255,255,255,0.05)"
        stroke-width="1.5"></path>
      <path
        d="M 480 500 A 20 20 0 0 1 500 480"
        fill="none"
        stroke="rgba(255,255,255,0.05)"
        stroke-width="1.5"></path>
      <!-- Outer border -->
      <rect
        x="1"
        y="1"
        width="498"
        height="498"
        fill="none"
        stroke="rgba(255,255,255,0.05)"
        stroke-width="1.5"></rect>
    </svg>

    <div class="hero-crest">
      <div class="hero-crest-img">
        <img
          src={bannerImage}
          alt="South Van FC youth soccer club crest, Vancouver BC"
          width="220"
          height="220"
          fetchpriority="high"
        />
      </div>

      <div class="hero-stats">
        <div class="hstat">
          <span class="hstat-num">2023</span>
          <span class="hstat-lbl">Founded</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: calc(100vh - 72px);
    background: var(--navy-dark);
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
  }

  /* ── Left ── */
  .hero-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 60px 80px 80px;
    position: relative;
    z-index: 2;
  }

  .hero-title {
    font-family: "Inter Variable", sans-serif;
    font-size: clamp(72px, 7vw, 112px);
    line-height: 0.88;
    letter-spacing: 2px;
    color: #fff;
    margin-bottom: 28px;
  }
  .hero-title em {
    font-style: normal;
    color: var(--gold);
    display: block;
  }

  .hero-title-kw {
    display: block;
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 1.5px;
    color: rgba(255, 255, 255, 0.45);
    text-transform: uppercase;
    margin-top: 16px;
  }

  .hero-sub {
    font-size: 18px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.62);
    max-width: 420px;
    margin-bottom: 44px;
    font-style: italic;
  }

  .hero-cta-block {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .hero-cta-label {
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.38);
    margin: 0;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .btn-main {
    display: block;
    line-height: 1.2;
  }

  .btn-sub {
    display: block;
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.5px;
    opacity: 0.72;
    margin-top: 2px;
  }

  /* ── Right ── */
  .hero-right {
    position: relative;
    background: var(--navy);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .field-pattern {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: repeating-linear-gradient(
      -60deg,
      transparent,
      transparent 28px,
      rgba(255, 255, 255, 0.025) 28px,
      rgba(255, 255, 255, 0.025) 30px
    );
  }

  .pitch-markings {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .hero-crest {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
  }

  .hero-crest-img {
    width: 220px;
    height: 220px;
    animation: floatY 4s ease-in-out infinite;
  }
  .hero-crest-img img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .hero-stats {
    display: flex;
    gap: 32px;
  }

  .hstat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hstat-num {
    font-family: "Inter Variable", sans-serif;
    font-size: 38px;
    color: white;
    line-height: 1;
  }

  .hstat-lbl {
    font-size: 10px;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-top: 4px;
  }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .hero-left {
      padding: 64px 28px;
    }
    .hero-right {
      min-height: 380px;
    }
    .hero-crest-img {
      width: 160px;
      height: 160px;
    }
    .hero-stats {
      gap: 20px;
    }
  }
</style>
