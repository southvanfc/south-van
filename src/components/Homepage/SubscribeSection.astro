---
import SubscribeForm from "../SubscribeForm.astro";
---

<section class="sub-section">
  <div class="sub-inner">
    <div class="sub-text">
      <span class="eyebrow eyebrow-gold">Stay Connected</span>
      <h2 class="section-title section-title-white">
        Club Updates,<br />Right to Your Inbox
      </h2>
      <p class="sub-body">
        Be the first to hear about new programs, tryout dates, match results, and community events from South Van FC.
      </p>
    </div>
    <div class="sub-form-wrap">
      <SubscribeForm source="homepage" theme="dark" showName={true} buttonLabel="Subscribe" />
    </div>
  </div>
</section>

<style>
  .sub-section {
    background: var(--navy);
    padding: 96px 80px;
  }

  .sub-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .section-title-white {
    color: #fff;
  }

  .sub-body {
    font-size: 16px;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.65);
    margin-top: 16px;
  }

  .sub-form-wrap {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    padding: 36px;
  }

  @media (max-width: 960px) {
    .sub-section {
      padding: 64px 28px;
    }
    .sub-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
