---
// src/components/Nav.astro
interface Props {
  activePage?:
    | "home"
    | "academy"
    | "coaches"
    | "blog"
    | "pricing"
    | "mens-team";
}

const { activePage = "home" } = Astro.props;

const links = [
  { key: "home", href: "/", label: "Home" },
  { key: "academy", href: "/academy/", label: "Youth Academy" },
  { key: "pricing", href: "/academy/pricing/", label: "Pricing" },
  { key: "coaches", href: "/our-coaches/", label: "Coaches" },
  { key: "mens-team", href: "/mens-team/", label: "Men's Team" },
  { key: "blogs", href: "/blogs/", label: "Blogs" },
];
---

<nav class="nav" id="nav">
  <a href="/" class="nav-logo">
    <div class="nav-mark">
      <img
        src="/assets/blue.png"
        alt="South Van FC crest"
        width="48"
        height="48"
      />
    </div>
    <span class="nav-brand">South Van FC</span>
  </a>

  <ul class="nav-links">
    {
      links.map(({ key, href, label }) => (
        <li>
          <a href={href} class:list={[{ active: activePage === key }]}>
            {label}
          </a>
        </li>
      ))
    }
    <li class="nav-dropdown">
      <button
        class="nav-cta nav-dropdown-toggle"
        aria-expanded="false"
        aria-haspopup="true"
      >
        Apply Now <span class="nav-dropdown-arrow">▾</span>
      </button>
      <ul class="nav-dropdown-menu" role="menu">
        <li role="none">
          <a href="/mens-team-application/" role="menuitem">Men's Squad</a>
        </li>
        <li role="none">
          <a href="/academy/player-evaluation/" role="menuitem">Youth Academy</a
          >
        </li>
      </ul>
    </li>
  </ul>

  <button
    class="nav-hamburger"
    id="hamburger"
    aria-label="Open menu"
    aria-expanded="false"
  >
    <span></span>
    <span></span>
    <span></span>
  </button>
</nav>

<!-- Mobile drawer -->
<div class="nav-drawer" id="drawer" aria-hidden="true">
  {
    links.map(({ key, href, label }) => (
      <a href={href} class:list={[{ active: activePage === key }]}>
        {label}
      </a>
    ))
  }
  <a href="/mens-team-application/" class="drawer-cta">Apply — Men's Squad</a>
  <a href="/academy/player-evaluation/" class="drawer-cta"
    >Apply — Youth Academy</a
  >
</div>

<script>
  const ham = document.getElementById("hamburger")!;
  const drawer = document.getElementById("drawer")!;

  // Dropdown
  const dropdownToggle = document.querySelector<HTMLButtonElement>(
    ".nav-dropdown-toggle",
  )!;
  const dropdownMenu =
    document.querySelector<HTMLElement>(".nav-dropdown-menu")!;

  dropdownToggle.addEventListener("click", (e) => {
    e.stopPropagation();
    const isOpen = dropdownToggle.getAttribute("aria-expanded") === "true";
    dropdownToggle.setAttribute("aria-expanded", String(!isOpen));
    dropdownMenu.classList.toggle("open", !isOpen);
  });

  document.addEventListener("click", (e) => {
    if (
      !dropdownToggle.contains(e.target as Node) &&
      !dropdownMenu.contains(e.target as Node)
    ) {
      dropdownToggle.setAttribute("aria-expanded", "false");
      dropdownMenu.classList.remove("open");
    }
  });

  ham.addEventListener("click", () => {
    const isOpen = ham.classList.toggle("open");
    drawer.classList.toggle("open", isOpen);
    ham.setAttribute("aria-expanded", String(isOpen));
    drawer.setAttribute("aria-hidden", String(!isOpen));
  });

  // Close on link click
  drawer.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => {
      ham.classList.remove("open");
      drawer.classList.remove("open");
      ham.setAttribute("aria-expanded", "false");
      drawer.setAttribute("aria-hidden", "true");
    }),
  );

  // Close on outside click
  document.addEventListener("click", (e) => {
    if (!ham.contains(e.target as Node) && !drawer.contains(e.target as Node)) {
      ham.classList.remove("open");
      drawer.classList.remove("open");
    }
  });
</script>
