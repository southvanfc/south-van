---
import { programs } from "../../data/programs-data";
import type { Programs } from "../../types/types";
import ProgramCard from "./ProgramCard.astro";

// src/components/academy/Programs.astro

const rowOne = programs.slice(0, 3);
const rowTwo = programs.slice(3);
---

<section class="programs" id="programs">
  <div class="programs-header">
    <div>
      <span class="eyebrow eyebrow-navy">Academy Pathways</span>
      <h2 class="section-title" style="margin-bottom: 0">
        Our Focused<br />Programs
      </h2>
    </div>
    <a href="/academy/player-evaluation" class="btn btn-navy">
      Request an Evaluation
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
      >
        <path d="M5 12h14M12 5l7 7-7 7"></path>
      </svg>
    </a>
  </div>

  <div class="prog-grid prog-grid-3">
    {rowOne.map((p) => <ProgramCard {...p} />)}
  </div>

  <div class="prog-grid prog-grid-2">
    {rowTwo.map((p) => <ProgramCard {...p} />)}
  </div>
</section>

<style>
  .programs {
    padding: 96px 80px;
  }

  .programs-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 24px;
    margin-bottom: 56px;
  }

  .prog-grid {
    display: grid;
    gap: 2px;
    background: var(--lt-gray);
    margin-bottom: 2px;
  }
  .prog-grid:last-child {
    margin-bottom: 0;
  }
  .prog-grid-3 {
    grid-template-columns: repeat(3, 1fr);
  }
  .prog-grid-2 {
    grid-template-columns: repeat(2, 1fr);
  }

  @media (max-width: 960px) {
    .programs {
      padding: 64px 28px;
    }
    .programs-header {
      flex-direction: column;
      align-items: flex-start;
    }
    .prog-grid-3,
    .prog-grid-2 {
      grid-template-columns: 1fr;
    }
  }
</style>
