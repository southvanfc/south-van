---
import type { Programs } from "../../types/types";
import ProgramCard from "./ProgramCard.astro";

// src/components/academy/Programs.astro

const programs: Programs[] = [
  {
    index: "01",
    badge: "Foundations",
    name: "Technical & Movement Fundamentals",
    bestFor: "Beginners",
    ages: "U6 & up",
    overview:
      "Ball mastery, body mechanics, and comfort under pressure. Designed for younger players but open to any age needing to develop or refine technical foundations.",
  },
  {
    index: "02",
    badge: "Select",
    name: "Game Development & Intelligence",
    bestFor: "Select Players",
    ages: "10-18",
    overview:
      "For players ready to move beyond technique. Training emphasises decision-making, tactical understanding, and reading the game at speed in a selective environment.",
  },
  {
    index: "03",
    badge: "Invite-Based",
    name: "High-Performance Pathway & Exposure",
    bestFor: "Advanced Players",
    ages: "10+",
    overview:
      "Prepares committed players for trials, showcases, and higher-level environments. Focused on match-speed performance and professional standards. Invite-based.",
  },
  {
    index: "04",
    badge: "Live Analysis",
    name: "Match Observation & In-Game Evaluation",
    bestFor: "Real-Match Feedback",
    ages: "12+",
    overview:
      "Coaches attend live matches to evaluate in real-game conditions. Players receive a post-match report with clear strengths, growth areas, and next-step recommendations.",
  },
  {
    index: "05",
    badge: "Film Room",
    name: "Individual Video Analysis",
    bestFor: "Technical Breakdown",
    ages: "12+",
    overview:
      "Detailed breakdown of match footage with annotated clips, tactical insights, and position-specific feedback for clear, actionable improvements.",
  },
];

const rowOne = programs.slice(0, 3);
const rowTwo = programs.slice(3);
---

<section class="programs" id="programs">
  <div class="programs-header">
    <div>
      <span class="eyebrow eyebrow-navy">Academy Pathways</span>
      <h2 class="section-title" style="margin-bottom: 0">
        Our Focused<br />Programs
      </h2>
    </div>
    <a href="/academy/player-evaluation" class="btn btn-navy">
      Request an Evaluation
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
      >
        <path d="M5 12h14M12 5l7 7-7 7"></path>
      </svg>
    </a>
  </div>

  <div class="prog-grid prog-grid-3">
    {rowOne.map((p) => <ProgramCard {...p} />)}
  </div>

  <div class="prog-grid prog-grid-2">
    {rowTwo.map((p) => <ProgramCard {...p} />)}
  </div>
</section>

<style>
  .programs {
    padding: 96px 80px;
  }

  .programs-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 24px;
    margin-bottom: 56px;
  }

  .prog-grid {
    display: grid;
    gap: 2px;
    background: var(--lt-gray);
    margin-bottom: 2px;
  }
  .prog-grid:last-child {
    margin-bottom: 0;
  }
  .prog-grid-3 {
    grid-template-columns: repeat(3, 1fr);
  }
  .prog-grid-2 {
    grid-template-columns: repeat(2, 1fr);
  }

  @media (max-width: 960px) {
    .programs {
      padding: 64px 28px;
    }
    .programs-header {
      flex-direction: column;
      align-items: flex-start;
    }
    .prog-grid-3,
    .prog-grid-2 {
      grid-template-columns: 1fr;
    }
  }
</style>
