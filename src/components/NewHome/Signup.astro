---
import type { ContactDetails } from "../../types/types";

// src/components/home/Contact.astro

const contactDetails: ContactDetails[] = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
    label: "Email",
    value: "southvanfc@gmail.com",
    href: "mailto:southvanfc@gmail.com",
  },
  {
    icon: "📍",
    label: "Location",
    value: "Lower Mainland, Vancouver, BC",
    href: null,
  },
  {
    icon: "⚽",
    label: "League",
    value: "VMSL Men's Open",
    href: null,
  },
];
---

<section class="contact">
  <div class="contact-grid">
    <!-- Left: text + CTAs -->
    <div>
      <span class="eyebrow eyebrow-navy">Get In Touch</span>
      <h2 class="section-title">
        Ready to<br />Make Your Move?
      </h2>
      <p class="section-body">
        Whether you're a player chasing your next challenge or a parent
        exploring development options for your child, we would love to hear from
        you.
      </p>
      <div class="contact-actions">
        <a href="/mens-team-application" class="btn btn-navy">
          Men's Squad Application
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
          >
        </a>
        <a href="/academy/player-evaluation" class="btn btn-outline-navy">
          Youth Evaluation
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
          >
        </a>
      </div>
    </div>

    <!-- Right: contact cards -->
    <div class="contact-cards">
      {
        contactDetails.map(({ icon, label, value, href }) => (
          <div class="ccard">
            <div class="ccard-icon" set:html={icon} />
            <div>
              <div class="ccard-label">{label}</div>
              {href ? (
                <a class="ccard-val" href={href}>
                  {value}
                </a>
              ) : (
                <div class="ccard-val">{value}</div>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .contact {
    background: var(--off-white);
    padding: 96px 80px;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .contact-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 36px;
  }

  .contact-cards {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ccard {
    display: flex;
    align-items: center;
    gap: 18px;
    background: #fff;
    border: 1px solid var(--lt-gray);
    border-radius: 10px;
    padding: 20px 24px;
  }

  .ccard-icon {
    width: 44px;
    height: 44px;
    border-radius: 8px;
    background: var(--navy);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    flex-shrink: 0;
  }

  .ccard-label {
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-light);
  }

  .ccard-val {
    font-size: 15px;
    font-weight: 500;
    color: var(--navy-dark);
    margin-top: 3px;
    text-decoration: none;
  }

  a.ccard-val:hover {
    text-decoration: underline;
    color: var(--navy);
  }

  @media (max-width: 960px) {
    .contact {
      padding: 64px 28px;
    }
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }
</style>
