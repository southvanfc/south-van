---
// src/components/home/Hero.astro

const { bannerImage } = Astro.props;
---

<section class="hero">
  <!-- Left: Copy -->
  <div class="hero-left">
    <span class="eyebrow eyebrow-gold fu d1">Vancouver Football Club</span>

    <h1 class="hero-title fu d2">
      South
      <em>Van FC</em>
    </h1>

    <p class="hero-sub fu d3">
      Built by the Community.<br />
      Developed for the Game.
    </p>

    <div class="hero-actions fu d4">
      <a href="/mens-team-application" class="btn btn-gold">
        Join the Squad
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
        >
      </a>
      <a href="/academy" class="btn btn-outline-white">
        View Academy
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
        >
      </a>
    </div>
  </div>

  <!-- Right: Floating crest -->
  <div class="hero-right">
    <div class="field-pattern"></div>
    <div class="hero-ring-outer"></div>

    <div class="hero-crest">
      <div class="hero-crest-img">
        <img
          src={bannerImage}
          alt="South Van FC crest"
          width="220"
          height="220"
        />
      </div>

      <div class="hero-stats">
        <div class="hstat">
          <span class="hstat-num">2023</span>
          <span class="hstat-lbl">Founded</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: calc(100vh - 72px);
    background: var(--navy-dark);
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
  }

  /* ── Left ── */
  .hero-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 60px 80px 80px;
    position: relative;
    z-index: 2;
  }

  .hero-title {
    font-family: "Inter Variable", sans-serif;
    font-size: clamp(72px, 7vw, 112px);
    line-height: 0.88;
    letter-spacing: 2px;
    color: #fff;
    margin-bottom: 28px;
  }
  .hero-title em {
    font-style: normal;
    color: var(--gold);
    display: block;
  }

  .hero-sub {
    font-size: 18px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.62);
    max-width: 420px;
    margin-bottom: 44px;
    font-style: italic;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  /* ── Right ── */
  .hero-right {
    position: relative;
    background: var(--navy);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .field-pattern {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 39px,
        rgba(255, 255, 255, 0.04) 39px,
        rgba(255, 255, 255, 0.04) 40px
      ),
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 39px,
        rgba(255, 255, 255, 0.04) 39px,
        rgba(255, 255, 255, 0.04) 40px
      );
  }

  .hero-ring-outer {
    position: absolute;
    width: 480px;
    height: 480px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.07);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    box-shadow:
      0 0 0 80px rgba(255, 255, 255, 0.025),
      0 0 0 160px rgba(255, 255, 255, 0.015);
    pointer-events: none;
  }

  .hero-crest {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
  }

  .hero-crest-img {
    width: 220px;
    height: 220px;
    animation: floatY 4s ease-in-out infinite;
  }
  .hero-crest-img img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .hero-stats {
    display: flex;
    gap: 32px;
  }

  .hstat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hstat-num {
    font-family: "Inter Variable", sans-serif;
    font-size: 38px;
    color: white;
    line-height: 1;
  }

  .hstat-lbl {
    font-size: 10px;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-top: 4px;
  }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .hero-left {
      padding: 64px 28px;
    }
    .hero-right {
      min-height: 380px;
    }
    .hero-crest-img {
      width: 160px;
      height: 160px;
    }
    .hero-stats {
      gap: 20px;
    }
  }
</style>
