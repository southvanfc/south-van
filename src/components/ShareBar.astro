---
interface Props {
  title: string;
  url: string;
  theme?: "dark" | "light";
  showLabel?: boolean;
}

const { title, url, theme = "light", showLabel = true } = Astro.props;

const btnClass = theme === "dark" ? "btn-outline-white" : "btn-outline-navy";
const twitterHref = `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}`;
const linkedinHref = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`;
---

<div
  class:list={[
    "share-wrap",
    { "share-bar": showLabel, "share-dark": theme === "dark" },
  ]}
>
  {showLabel && <span class="share-label">Share this article</span>}
  <div class="share-actions">
    <a
      class={`btn ${btnClass} btn-sm share-btn`}
      href={twitterHref}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Share on X / Twitter"
    >
      <svg
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.261 5.632L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"
        ></path>
      </svg>
      Twitter
    </a>
    <a
      class={`btn ${btnClass} btn-sm share-btn`}
      href={linkedinHref}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Share on LinkedIn"
    >
      <svg
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
        ></path>
      </svg>
      LinkedIn
    </a>
    <button
      class={`btn ${btnClass} btn-sm share-btn copy-link-btn`}
      aria-label="Copy link to article"
    >
      <svg
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
        ></path>
        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
        ></path>
      </svg>
      Copy Link
    </button>
  </div>
</div>

<style>
  .share-bar {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--lt-gray);
  }
  .share-label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-mid);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }
  .share-dark .share-label {
    color: rgba(255, 255, 255, 0.55);
  }
  .share-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  @media (max-width: 960px) {
    .share-bar {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<script>
  document.querySelectorAll(".copy-link-btn").forEach((btn) => {
    btn.addEventListener("click", function () {
      navigator.clipboard.writeText(window.location.href).then(() => {
        const original = btn.innerHTML;
        btn.textContent = "Copied!";
        setTimeout(() => {
          btn.innerHTML = original;
        }, 2000);
      });
    });
  });
</script>
