---
// src/components/coaches/CoachGrid.astro
import { coaches } from "../../data/coaches-data";
import CoachCard from "./CoachCard.astro";
---

<section class="coach-grid-section">
  <div class="section-header">
    <span class="eyebrow eyebrow-navy">Meet the Team</span>
    <h2 class="section-title">Our Coaching Staff</h2>
  </div>

  <div class="coach-grid">
    {coaches.map((coach) => <CoachCard {...coach} />)}
  </div>
</section>

<style>
  .coach-grid-section {
    padding: 96px 80px;
  }

  .section-header {
    margin-bottom: 56px;
  }

  .coach-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  @media (max-width: 960px) {
    .coach-grid-section {
      padding: 64px 28px;
    }
    .coach-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .coach-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
