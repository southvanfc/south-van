---
import CoachesHero from "../components/CoachesPage/CoachesHero.astro";
import CoachGrid from "../components/CoachesPage/CoachGrid.astro";
import CoachPhilosophy from "../components/CoachesPage/CoachPhilosophy.astro";
import Cta from "../components/Cta.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const seo = {
  title: "Soccer Coaches Vancouver | South Van FC Academy Staff",
  description:
    "Meet South Van FC's coaching team — Head Coach Harjit Kainth, Dipinder Kainth, and UBC Kinesiology-certified fitness coach Shanil Sharma. Experienced, credentialed, community-driven.",
  keywords:
    "South Van FC coaches, soccer coach Vancouver, football coach Vancouver, academy coach Vancouver, youth soccer coaching, player development coach",
  ogImage: "https://www.southvanfc.com/og/og-default.png",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://www.southvanfc.com/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Our Coaches",
      item: "https://www.southvanfc.com/our-coaches/",
    },
  ],
};
---

<BaseLayout seo={seo}>
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbSchema)}
  />
  <CoachesHero />
  <CoachGrid />
  <CoachPhilosophy />
  <Cta
    title="Train With<br />Our Coaches"
    body="Whether you're joining the men's squad or the academy, our coaching staff is ready to develop your game."
    links={[
      {
        href: "/academy/player-evaluation",
        label: "Request Evaluation",
        style: "navy",
      },
      {
        href: "/mens-team-application",
        label: "Men's Application",
        style: "outline-navy",
      },
    ]}
  />
</BaseLayout>
