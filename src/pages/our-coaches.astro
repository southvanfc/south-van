---
import CoachesHero from "../components/CoachesPage/CoachesHero.astro";
import CoachGrid from "../components/CoachesPage/CoachGrid.astro";
import CoachPhilosophy from "../components/CoachesPage/CoachPhilosophy.astro";
import Cta from "../components/Cta.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const seo = {
  title: "Soccer Coaches Vancouver | South Van FC Academy Staff",
  description:
    "Meet South Van FC's coaching team — Head Coach Harjit Kainth, Dipinder Kainth, and UBC Kinesiology-certified fitness coach Shanil Sharma. Experienced, credentialed, community-driven.",
  keywords:
    "South Van FC coaches, soccer coach Vancouver, football coach Vancouver, academy coach Vancouver, youth soccer coaching, player development coach",
  ogImage: "https://www.southvanfc.com/og/og-default.png",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://www.southvanfc.com/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Our Coaches",
      item: "https://www.southvanfc.com/our-coaches/",
    },
  ],
};

const coachSchemas = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": "https://www.southvanfc.com/our-coaches/#harjit-kainth",
    name: "Harjit Kainth",
    jobTitle: "Head Coach",
    worksFor: {
      "@type": "SportsClub",
      "@id": "https://www.southvanfc.com/#sportsclub",
      name: "South Van FC",
    },
    url: "https://www.southvanfc.com/our-coaches",
    description:
      "Head Coach at South Van FC. Elite youth pathway background including TSS Academy, Vancouver Selects, and Coastal BC Super Y League. International experience in Salzburg and with Dynamo Kyiv Youth Academy. Pursuing Canada Soccer C Diploma.",
    knowsAbout: [
      "Soccer Coaching",
      "Youth Player Development",
      "Tactical Training",
      "Technical Training",
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": "https://www.southvanfc.com/our-coaches/#dipinder-kainth",
    name: "Dipinder Kainth",
    jobTitle: "Men's Team Coach",
    worksFor: {
      "@type": "SportsClub",
      "@id": "https://www.southvanfc.com/#sportsclub",
      name: "South Van FC",
    },
    url: "https://www.southvanfc.com/our-coaches",
    description:
      "Men's Team Coach at South Van FC. VMSL competitive playing background. Pursuing Canada Soccer C Diploma.",
    knowsAbout: [
      "Soccer Coaching",
      "Men's Football",
      "Skill Development",
      "Leadership",
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": "https://www.southvanfc.com/our-coaches/#shanil-sharma",
    name: "Shanil Sharma",
    jobTitle: "Strength & Conditioning Coach",
    worksFor: {
      "@type": "SportsClub",
      "@id": "https://www.southvanfc.com/#sportsclub",
      name: "South Van FC",
    },
    url: "https://www.southvanfc.com/our-coaches",
    description:
      "Strength and Conditioning Coach at South Van FC. UBC Kinesiology graduate specializing in strength, conditioning, and injury rehabilitation. Member of the National Coaching Certification Program.",
    alumniOf: {
      "@type": "CollegeOrUniversity",
      name: "University of British Columbia",
    },
    knowsAbout: [
      "Strength and Conditioning",
      "Kinesiology",
      "Injury Rehabilitation",
      "Plyometrics",
      "Sports Science",
    ],
  },
];
---

<BaseLayout seo={seo}>
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbSchema)}
  />
  {
    coachSchemas.map((schema) => (
      <script
        is:inline
        slot="head"
        type="application/ld+json"
        set:html={JSON.stringify(schema)}
      />
    ))
  }
  <CoachesHero />
  <CoachGrid />
  <CoachPhilosophy />
  <Cta
    title="Train With<br />Our Coaches"
    body="Whether you're joining the men's squad or the academy, our coaching staff is ready to develop your game."
    links={[
      {
        href: "/academy/player-evaluation",
        label: "Request Evaluation",
        style: "navy",
      },
      {
        href: "/mens-team-application",
        label: "Men's Application",
        style: "outline-navy",
      },
    ]}
  />
</BaseLayout>
