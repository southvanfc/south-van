---
import BaseLayout from "../layouts/BaseLayout.astro";
import MensHero from "../components/MensEval/MensHero.astro";
import MensProcess from "../components/MensEval/MensProcess.astro";
import MensCulture from "../components/MensEval/MensCulture.astro";
import MensApplicationForm from "../components/MensEval/MensApplicationForm.astro";

const seo = {
  title: "Men's Team Application | South Van FC Open Squad Vancouver",
  description:
    "Apply to join South Van FC's Open Men's team in Vancouver. We welcome players of all backgrounds committed to a technical, development-focused approach to football.",
  keywords:
    "South Van FC men's team, adult soccer Vancouver, open men's soccer Vancouver, join soccer team Vancouver, Vancouver soccer tryout, adult football team Vancouver",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://www.southvanfc.com/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Men's Team Application",
      item: "https://www.southvanfc.com/mens-team-application/",
    },
  ],
};
---

<BaseLayout seo={seo}>
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbSchema)}
  />
  <MensHero />
  <MensProcess />
  <MensCulture />

  <div class="form-wrap">
    <div class="form-panel">
      <div class="panel-header">
        <h2 class="panel-title">Squad Application Form</h2>
        <p class="panel-sub">
          All fields marked <strong>*</strong> are required. We review every application
          personally and respond within 48 hours.
        </p>
      </div>
      <MensApplicationForm />
    </div>
  </div>
</BaseLayout>

<style>
  .form-wrap {
    background: #f7f8fc;
    padding: 64px 80px;
  }
  .form-panel {
    background: #fff;
    border: 1px solid #eef0f7;
    border-radius: 16px;
    padding: 52px 64px 64px;
    max-width: 820px;
    margin: 0 auto;
    box-shadow: 0 4px 40px rgba(1, 52, 120, 0.05);
  }
  .panel-header {
    margin-bottom: 4px;
  }
  .panel-title {
    font-family: "Bebas Neue", sans-serif;
    font-size: 30px;
    letter-spacing: 1px;
    color: #011f4a;
    margin-bottom: 6px;
  }
  .panel-sub {
    font-size: 13px;
    color: #6b7a9e;
    line-height: 1.6;
  }
  .panel-sub strong {
    font-weight: 600;
    color: #3d4d6e;
  }

  @media (max-width: 960px) {
    .form-wrap {
      padding: 40px 28px;
    }
    .form-panel {
      padding: 36px 28px 52px;
      border-radius: 12px;
    }
  }
</style>
