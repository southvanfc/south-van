---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Homepage/Hero.astro";
import StatsBand from "../components/Homepage/StatsBand.astro";
import Squads from "../components/Homepage/Squads.astro";
import Values from "../components/Homepage/Values.astro";
import Faq from "../components/Homepage/Faq.astro";
import Signup from "../components/Homepage/Signup.astro";

const seo = {
  title: "South Van FC | Youth Soccer Academy & Football Club Vancouver",
  description:
    "South Van FC is Vancouver's technical youth soccer academy and competitive men's football club. Development programs for U8–U18 players in South Vancouver, BC.",
  keywords:
    "South Van FC, Vancouver football club, soccer club Vancouver, soccer academy Vancouver, player development Vancouver, adult soccer Vancouver, youth soccer Vancouver, BC soccer",
  ogImage: "/og/og-default.png",
};

const stats = [
  { value: "1:1", label: "Focused Coaching" },
  { value: "4", label: "Pillars Every Session" },
  { value: "IDP", label: "Individual Development Plan" },
  { value: "YVR", label: "Lower Mainland" },
];

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://www.southvanfc.com/#website",
  url: "https://www.southvanfc.com",
  name: "South Van FC",
  description:
    "Community-built football club in Vancouver with a technical-first Development Academy.",
};

const sportsTeamSchema = {
  "@context": "https://schema.org",
  "@type": "SportsOrganization",
  "@id": "https://www.southvanfc.com/#sportsorganization",
  name: "South Van FC",
  url: "https://www.southvanfc.com",
  sport: "Soccer",
  areaServed: {
    "@type": "Place",
    name: "Vancouver, BC, Canada",
  },
  sameAs: ["https://www.instagram.com/southvanfc"],
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "SportsClub",
  "@id": "https://www.southvanfc.com/#sportsclub",
  name: "South Van FC",
  url: "https://www.southvanfc.com",
  email: "southvanfc@gmail.com",
  description:
    "Community-built football club in Vancouver with a technical-first youth soccer academy and competitive men's team.",
  address: {
    "@type": "PostalAddress",
    addressLocality: "South Vancouver",
    addressRegion: "BC",
    addressCountry: "CA",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 49.2141,
    longitude: -123.084,
  },
  areaServed: {
    "@type": "Place",
    name: "Lower Mainland, BC, Canada",
  },
  sameAs: ["https://www.instagram.com/southvanfc"],
};
---

<BaseLayout seo={seo}>
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(websiteSchema)}
  />
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(sportsTeamSchema)}
  />
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(localBusinessSchema)}
  />
  <Hero bannerImage={"/assets/white.png"} />
  <StatsBand stats={stats} />
  <Squads />
  <Values />
  <Faq />
  <Signup />
</BaseLayout>
