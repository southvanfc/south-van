---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AcademyHero from "../../components/SoccerAcademy/AcademyHero.astro";
import Philosophy from "../../components/SoccerAcademy/Philosophy.astro";
import Programs from "../../components/SoccerAcademy/Programs.astro";
import Evaluation from "../../components/SoccerAcademy/Evaluation.astro";
import Cta from "../../components/Cta.astro";
import { programs } from "../../data/programs-data";

const seo = {
  title: "Soccer Academy Vancouver | South Van FC",
  description:
    "Technical soccer training for players U8 through adult in Vancouver. Small-group sessions, video analysis, and individual development plans.",
  ogImage: "/og/og-default.png",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://www.southvanfc.com/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Soccer Academy",
      item: "https://www.southvanfc.com/soccer-academy/",
    },
  ],
};

const programsSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "South Van FC Soccer Academy Programs",
  itemListElement: programs.map((program, i) => {
    const course = {
      "@type": "Course",
      name: program.name,
      description: program.overview,
      provider: {
        "@type": "Organization",
        "@id": "https://www.southvanfc.com/#organization",
        name: "South Van FC",
      },
      audience: {
        "@type": "EducationalAudience",
        educationalRole: program.bestFor,
      },
      ...(program.price
        ? {
            offers: {
              "@type": "Offer",
              price: program.price.replace(/[^0-9.]/g, ""),
              priceCurrency: "CAD",
            },
          }
        : {}),
    };

    return {
      "@type": "ListItem",
      position: i + 1,
      item: course,
    };
  }),
};
---

<BaseLayout seo={seo}>
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbSchema)}
  />
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(programsSchema)}
  />
  <AcademyHero />
  <Philosophy />
  <Evaluation />
  <Programs />
  <Cta
    title="Start Your Development<br />Journey Today"
    body="Join South Van FC and unlock your full potential. Discover the right program or book a personalised evaluation."
    links={[
      {
        href: "/soccer-academy/player-evaluation/",
        label: "Request Player Evaluation",
        style: "navy",
      },
      {
        href: "/our-coaches/",
        label: "Meet the Coaches",
        style: "outline-navy",
      },
    ]}
  />
</BaseLayout>
