---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ShareBar from "../../components/ShareBar.astro";
import SubscribeForm from "../../components/SubscribeForm.astro";

const { slug } = Astro.params;
const posts = await getCollection("blog");
const post = posts.find((p) => p.id === slug);

if (!post) {
  return Astro.redirect("/blogs");
}

const { Content } = await render(post);

const recentPosts = posts
  .filter((p) => p.data.author === post.data.author && p.id !== post.id)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

function readingTime(body: string) {
  return Math.max(1, Math.round(body.split(/\s+/).length / 200));
}

const seo = {
  title: `${post.data.seoTitle} | South Van FC Blog`,
  description: post.data.description,
  ogType: "article" as const,
  ogImage: post.data.coverImage ?? post.data.image ?? "/og/og-default.png",
  canonical: `/blogs/${post.id}`,
};

function formatDate(date: Date) {
  return date.toLocaleDateString("en-CA", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://www.southvanfc.com/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Blog",
      item: "https://www.southvanfc.com/blogs/",
    },
    {
      "@type": "ListItem",
      position: 3,
      name: post.data.title,
      item: `https://www.southvanfc.com/blogs/${post.id}/`,
    },
  ],
};

const authorId: Record<string, string> = {
  "Harjit Kainth": "https://www.southvanfc.com/our-coaches/#harjit-kainth",
  "Dipinder Kainth": "https://www.southvanfc.com/our-coaches/#dipinder-kainth",
  "Shanil Sharma": "https://www.southvanfc.com/our-coaches/#shanil-sharma",
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  url: `https://www.southvanfc.com/blogs/${post.id}/`,
  image:
    post.data.coverImage ??
    post.data.image ??
    "https://www.southvanfc.com/og/og-default.png",
  publisher: {
    "@type": "SportsClub",
    "@id": "https://www.southvanfc.com/#sportsclub",
    name: "South Van FC",
  },
  author: {
    "@type": "Person",
    "@id": authorId[post.data.author] ?? undefined,
    name: post.data.author,
  },
};
---

<BaseLayout seo={seo}>
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(articleSchema)}
  />
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbSchema)}
  />

  <article class="post-page">
    <header class="post-hero">
      <div class="post-hero-inner">
        <a href="/blogs/" class="post-back">← All Posts</a>
        {
          post.data.category && (
            <span class="blog-card-cat">{post.data.category}</span>
          )
        }
        <h1 class="post-title">{post.data.title}</h1>
        <p class="post-desc">{post.data.description}</p>
        <div class="post-meta">
          <div class="post-meta-author">
            {
              post.data.image && (
                <Image
                  class="author-avatar"
                  src={post.data.image}
                  alt={post.data.imageAlt || post.data.author}
                  width={85}
                  height={85}
                />
              )
            }
            <div>
              <div>
                <span>{post.data.author}</span>
              </div>
              <time datetime={post.data.pubDate.toISOString()}>
                {formatDate(post.data.pubDate)}
              </time>
            </div>
          </div>
          <ShareBar title={post.data.title} url={Astro.url.href} theme="dark" />
        </div>
      </div>
    </header>

    {
      post.data.coverImage && (
        <div class="post-cover">
          <div class="post-cover-frame">
            <Image
              class="post-cover-img"
              src={post.data.coverImage}
              alt={post.data.coverImageAlt ?? post.data.title}
              loading="eager"
              width={1200}
              height={630}
            />
          </div>
        </div>
      )
    }

    <div class="post-body">
      <div class="prose">
        <Content />
      </div>
      <script>
        document.querySelectorAll(".prose a[href]").forEach((a) => {
          const href = (a as HTMLAnchorElement).href;
          if (href && !href.startsWith(location.origin)) {
            a.setAttribute("target", "_blank");
            a.setAttribute("rel", "noopener noreferrer");
          }
        });
      </script>

      {
        post.data.tags && post.data.tags.length > 0 && (
          <div class="post-tags">
            {post.data.tags.map((tag) => (
              <span class="pill pill-navy">{tag}</span>
            ))}
          </div>
        )
      }

      <ShareBar title={post.data.title} url={Astro.url.href} theme="light" />

      <div class="post-footer">
        <a href="/blogs/" class="btn btn-outline-navy btn-sm">← Back to Blog</a>
      </div>
    </div>

    <section class="blog-cta-cards">
      <div class="blog-cta-cards-inner">
        <div class="blog-cta-card">
          <span class="blog-cta-card-eyebrow">Men's Team</span>
          <h3 class="blog-cta-card-title">Ready to play?</h3>
          <p class="blog-cta-card-body">
            Competitive men's soccer in Vancouver. If you're looking for a club
            that takes development seriously, we want to hear from you.
          </p>
          <div class="blog-cta-card-actions">
            <a href="/mens-team/" class="btn btn-navy btn-sm"
              >Join the Men's Team</a
            >
          </div>
        </div>
        <div class="blog-cta-card">
          <span class="blog-cta-card-eyebrow">Youth Academy</span>
          <h3 class="blog-cta-card-title">Is your child a player?</h3>
          <p class="blog-cta-card-body">
            Long-term development over short-term results. Start with a free
            evaluation and see if we're the right fit.
          </p>
          <div class="blog-cta-card-actions">
            <a href="/academy/player-evaluation/" class="btn btn-navy btn-sm"
              >Request an Evaluation</a
            >
            <a href="/academy/" class="btn btn-outline-navy btn-sm"
              >Explore the Academy</a
            >
          </div>
        </div>
      </div>
    </section>

    <div class="blog-subscribe">
      <div class="blog-subscribe-inner">
        <div class="blog-subscribe-text">
          <span class="blog-subscribe-eyebrow">Stay in the loop</span>
          <h3 class="blog-subscribe-heading">Enjoyed this article?</h3>
          <p class="blog-subscribe-body">
            Get the latest posts, club updates, and promos from South Van FC
            delivered straight to your inbox.
          </p>
        </div>
        <div class="blog-subscribe-form">
          <SubscribeForm
            source="blog"
            theme="light"
            showName={true}
            buttonLabel="Subscribe"
          />
        </div>
      </div>
    </div>

    <section class="recent-articles">
      <div class="recent-articles-inner">
        <div class="recent-heading">
          <span class="recent-label">Keep Reading</span>
          <h2 class="recent-title">More from {post.data.author}</h2>
        </div>

        {
          recentPosts.length === 0 ? (
            <div class="recent-empty">
              <span class="recent-empty-icon">✍️</span>
              <p class="recent-empty-headline">
                Still warming up the keyboard…
              </p>
              <p class="recent-empty-sub">
                {post.data.author} is sharpening their next piece. Great writing
                takes time, check back soon.
              </p>
            </div>
          ) : (
            <div class="recent-grid">
              {recentPosts.map((p) => (
                <a href={`/blogs/${p.id}`} class="recent-card">
                  {p.data.category && (
                    <span class="recent-card-cat">{p.data.category}</span>
                  )}
                  <h3 class="recent-card-title">{p.data.title}</h3>
                  <p class="recent-card-desc">{p.data.description}</p>
                  <div class="recent-card-meta">
                    {p.data.image && (
                      <Image
                        class="recent-card-avatar"
                        src={p.data.image}
                        alt={p.data.imageAlt || p.data.author}
                        width={28}
                        height={28}
                      />
                    )}
                    <div class="recent-card-byline">
                      <span class="recent-card-author">{p.data.author}</span>
                      <span class="recent-card-detail">
                        {formatDate(p.data.pubDate)} ·{" "}
                        {readingTime(p.body ?? "")} min read
                      </span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          )
        }
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  /* Hero */
  .post-hero {
    background: var(--navy-dark);
    padding: 80px 80px 64px;
  }
  .post-hero-inner {
    max-width: 810px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .post-back {
    font-size: 13px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    letter-spacing: 0.3px;
    transition: color 0.2s;
    width: fit-content;
  }
  .post-back:hover {
    color: var(--gold);
  }

  .blog-card-cat {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
  }

  .post-title {
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: 0.5px;
    color: #fff;
  }

  .post-desc {
    font-size: 17px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    max-width: 600px;
  }

  .post-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.45);
    padding-top: 4px;
  }
  .post-meta-author {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .meta-dot {
    opacity: 0.5;
  }

  .author-avatar {
    width: 85px;
    height: 85px;
    border-radius: 50%;
    object-fit: contain;
    flex-shrink: 0;
  }

  /* Cover image */
  .post-cover {
    max-width: 810px;
    margin: 0 auto;
    padding: 40px 80px 0;
  }
  .post-cover-frame {
    aspect-ratio: 2 / 1;
    border-radius: 12px;
    overflow: hidden;
  }
  .post-cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Body */
  .post-body {
    max-width: 810px;
    margin: 0 auto;
    padding: 48px 80px 96px;
  }

  /* Prose styles — applied to rendered markdown */
  .prose {
    color: var(--text-dark);
    font-size: 17px;
    line-height: 1.8;
  }
  .prose :global(h2) {
    font-size: clamp(22px, 2.5vw, 28px);
    font-weight: 700;
    color: var(--navy-dark);
    margin-top: 48px;
    margin-bottom: 16px;
    line-height: 1.2;
  }
  .prose :global(h3) {
    font-size: clamp(18px, 2vw, 22px);
    font-weight: 700;
    color: var(--navy-dark);
    margin-top: 36px;
    margin-bottom: 12px;
  }
  .prose :global(p) {
    margin-bottom: 20px;
    color: var(--text-mid);
  }
  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 24px;
    margin-bottom: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .prose :global(ul) {
    list-style: disc;
  }
  .prose :global(ol) {
    list-style: decimal;
  }
  .prose :global(li) {
    color: var(--text-mid);
    font-size: 17px;
    line-height: 1.7;
  }
  .prose :global(strong) {
    font-weight: 700;
    color: var(--text-dark);
  }
  .prose :global(em) {
    font-style: italic;
  }
  .prose :global(a) {
    color: var(--navy);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose :global(a:hover) {
    color: var(--gold);
  }
  .prose :global(blockquote) {
    border-left: 3px solid var(--gold);
    padding: 4px 20px;
    margin: 24px 0;
    color: var(--text-mid);
    font-style: italic;
  }
  .prose :global(code) {
    background: var(--lt-gray);
    border-radius: 4px;
    padding: 2px 6px;
    font-size: 14px;
    font-family: monospace;
  }
  .prose :global(pre) {
    background: var(--navy-dark);
    color: #e6edf3;
    border-radius: 8px;
    padding: 20px 24px;
    overflow-x: auto;
    margin: 24px 0;
  }
  .prose :global(pre code) {
    background: none;
    padding: 0;
    font-size: 14px;
    color: inherit;
  }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--lt-gray);
    margin: 40px 0;
  }
  .prose :global(img) {
    border-radius: 8px;
    margin: 24px auto;
    max-height: 480px;
    width: auto;
  }

  /* Tags */
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--lt-gray);
  }

  /* Footer */
  .post-footer {
    margin-top: 40px;
  }

  /* Blog CTA Cards */
  .blog-cta-cards {
    background: var(--off-white);
    border-top: 1px solid var(--lt-gray);
    padding: 56px 80px;
  }
  .blog-cta-cards-inner {
    max-width: 810px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .blog-cta-card {
    background: #fff;
    border: 1px solid var(--lt-gray);
    border-radius: 12px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .blog-cta-card-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
  }
  .blog-cta-card-title {
    font-size: clamp(18px, 2vw, 22px);
    font-weight: 800;
    color: var(--navy-dark);
    line-height: 1.2;
    margin: 0;
  }
  .blog-cta-card-body {
    font-size: 14px;
    line-height: 1.7;
    color: var(--text-mid);
    margin: 0;
    flex: 1;
  }
  .blog-cta-card-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 6px;
  }

  /* Blog Subscribe CTA */
  .blog-subscribe {
    background: var(--gold-pale);
    border-top: 1px solid #f0e4b0;
    border-bottom: 1px solid #f0e4b0;
    padding: 56px 80px;
  }
  .blog-subscribe-inner {
    max-width: 810px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .blog-subscribe-eyebrow {
    display: block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 8px;
  }
  .blog-subscribe-heading {
    font-size: clamp(18px, 2.5vw, 24px);
    font-weight: 800;
    color: var(--navy-dark);
    line-height: 1.2;
    margin-bottom: 10px;
  }
  .blog-subscribe-body {
    font-size: 14px;
    line-height: 1.7;
    color: var(--text-mid);
    margin: 0;
  }

  /* Recent Articles */
  .recent-articles {
    background: var(--off-white);
    border-top: 1px solid var(--lt-gray);
    padding: 72px 80px;
  }
  .recent-articles-inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .recent-heading {
    margin-bottom: 40px;
  }
  .recent-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
    display: block;
    margin-bottom: 8px;
  }
  .recent-title {
    font-size: clamp(22px, 2.5vw, 30px);
    font-weight: 800;
    color: var(--navy-dark);
    line-height: 1.2;
  }
  .recent-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }
  .recent-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    background: #fff;
    border: 1px solid var(--lt-gray);
    border-radius: 12px;
    padding: 24px;
    text-decoration: none;
    color: inherit;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }
  .recent-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 40px rgba(1, 52, 120, 0.1);
  }
  .recent-card-cat {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
  }
  .recent-card-title {
    font-size: 17px;
    font-weight: 700;
    color: var(--navy-dark);
    line-height: 1.3;
    margin: 0;
  }
  .recent-card-desc {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-mid);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }
  .recent-card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 4px;
  }
  .recent-card-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    object-fit: contain;
    flex-shrink: 0;
  }
  .recent-card-byline {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .recent-card-author {
    font-size: 12px;
    font-weight: 600;
    color: var(--text-dark);
  }
  .recent-card-detail {
    font-size: 11px;
    color: var(--text-light);
  }
  .recent-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    border: 2px dashed var(--mid-gray);
    border-radius: 12px;
    padding: 48px 32px;
    text-align: center;
    max-width: 480px;
  }
  .recent-empty-icon {
    font-size: 32px;
  }
  .recent-empty-headline {
    font-size: 17px;
    font-weight: 700;
    color: var(--navy-dark);
    margin: 0;
  }
  .recent-empty-sub {
    font-size: 14px;
    color: var(--text-mid);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 960px) {
    .post-hero {
      padding: 56px 28px 48px;
    }
    .post-cover {
      padding: 24px 28px 0;
    }
    .post-body {
      padding: 40px 28px 72px;
    }
    .blog-cta-cards {
      padding: 40px 28px;
    }
    .blog-cta-cards-inner {
      grid-template-columns: 1fr;
    }
    .blog-subscribe {
      padding: 40px 28px;
    }
    .blog-subscribe-inner {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .recent-articles {
      padding: 56px 28px;
    }
  }
</style>
