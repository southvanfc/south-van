---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const seo = {
  title: "Soccer Blog Vancouver | Youth Development & Training Tips",
  description:
    "Soccer insights for Vancouver parents and players. Youth development tips, training advice, player stories, and club news from South Van FC's coaching team.",
  keywords: "South Van FC blog, Vancouver football news, soccer club updates",
  canonical: "/blogs",
};

function formatDate(date: Date) {
  return date.toLocaleDateString("en-CA", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

function readingTime(body: string) {
  const words = body.trim().split(/\s+/).length;
  return `${Math.max(1, Math.round(words / 200))} min read`;
}
---

<BaseLayout seo={seo}>
  <section class="blog-hero">
    <div class="blog-hero-inner">
      <span class="eyebrow eyebrow-gold">From the Club</span>
      <h1 class="section-title section-title-white">
        South Van FC Blog. Training Tips & Club News
      </h1>
      <p class="section-body section-body-white">
        News, insights, and stories from inside South Van FC.
      </p>
    </div>
  </section>

  <section class="blog-list-section section">
    {
      posts.length === 0 ? (
        <p class="blog-empty">No posts yet — check back soon.</p>
      ) : (
        <div class="blog-grid">
          {posts.map((post) => (
            <a href={`/blogs/${post.slug}`} class="blog-card">
              <div class="blog-card-body">
                {post.data.category && (
                  <span class="blog-card-cat">{post.data.category}</span>
                )}
                <h2 class="blog-card-title">{post.data.title}</h2>
                <p class="blog-card-desc">{post.data.description}</p>
                <div class="blog-card-footer">
                  <div class="blog-card-author">
                    {post.data.image && (
                      <img
                        class="blog-card-avatar"
                        src={post.data.image}
                        alt={post.data.author}
                      />
                    )}
                    <span class="blog-card-author-name">
                      {post.data.author}
                    </span>
                  </div>
                  <div class="blog-card-dateline">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {formatDate(post.data.pubDate)}
                    </time>
                    <span class="blog-card-read">
                      {readingTime(post.body ?? "")}
                    </span>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>

<style>
  /* Hero */
  .blog-hero {
    background: var(--navy-dark);
    padding: 96px 80px 80px;
  }
  .blog-hero-inner {
    max-width: 640px;
  }
  .blog-hero .section-title {
    margin-bottom: 16px;
  }

  /* List */
  .blog-list-section {
    max-width: 1200px;
    margin: 0 auto;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 32px;
  }

  .blog-card {
    background: #fff;
    border: 1px solid var(--lt-gray);
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition:
      box-shadow 0.2s,
      transform 0.2s;
  }
  .blog-card:hover {
    box-shadow: 0 8px 40px rgba(1, 52, 120, 0.1);
    transform: translateY(-3px);
  }

  .blog-card-body {
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .blog-card-cat {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
  }

  .blog-card-title {
    font-size: 20px;
    font-weight: 700;
    line-height: 1.25;
    color: var(--navy-dark);
  }

  .blog-card-desc {
    font-size: 14px;
    color: var(--text-mid);
    line-height: 1.65;
    flex: 1;
  }

  .blog-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--lt-gray);
  }

  .blog-card-author {
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: 0;
  }

  .blog-card-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .blog-card-author-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--navy-dark);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .blog-card-dateline {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
    flex-shrink: 0;
    font-size: 12px;
    color: var(--text-light);
  }

  .blog-card-read {
    font-size: 11px;
    color: var(--gold);
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  .blog-empty {
    color: var(--text-light);
    font-size: 16px;
    text-align: center;
    padding: 48px 0;
  }

  @media (max-width: 960px) {
    .blog-hero {
      padding: 64px 28px 56px;
    }
    .blog-list-section {
      padding: 56px 28px;
    }
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
