---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AcademyHero from "../../components/Academy/AcademyHero.astro";
import Philosophy from "../../components/Academy/Philosophy.astro";
import Programs from "../../components/Academy/Programs.astro";
import Evaluation from "../../components/Academy/Evaluation.astro";
import Cta from "../../components/Cta.astro";

const seo = {
  title: "Youth Soccer Academy Vancouver | South Van FC",
  description:
    "Technical soccer training for players U8–U18 in Vancouver. Small-group sessions, video analysis, and individual development plans. Serious development without the club politics.",
  keywords:
    "South Van FC Academy, soccer academy Vancouver, football academy Vancouver, player development Vancouver, technical soccer training, individual development plan soccer, youth football Vancouver",
  ogImage: "/og/og-default.png",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://www.southvanfc.com/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Academy",
      item: "https://www.southvanfc.com/academy/",
    },
  ],
};
---

<BaseLayout seo={seo}>
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbSchema)}
  />
  <AcademyHero />
  <Philosophy />
  <Evaluation />
  <Programs />
  <Cta
    title="Start Your Development<br />Journey Today"
    body="Join South Van FC and unlock your full potential. Discover the right program or book a personalised evaluation."
    links={[
      {
        href: "/academy/player-evaluation",
        label: "Request Player Evaluation",
        style: "navy",
      },
      {
        href: "/our-coaches",
        label: "Meet the Coaches",
        style: "outline-navy",
      },
    ]}
  />
</BaseLayout>
