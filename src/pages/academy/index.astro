---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AcademyHero from "../../components/NewAcademy/AcademyHero.astro";
import Philosophy from "../../components/NewAcademy/Philosophy.astro";
import Programs from "../../components/NewAcademy/Programs.astro";
import Evaluation from "../../components/NewAcademy/Evaluation.astro";
import Cta from "../../components/Cta.astro";

const pageTitle: string = "A Connected Football Experience";

const seo = {
  title: "SouthVan FC | Vancouver Football Club & Development Academy",
  description:
    "SouthVan FC is a community-built club in Vancouver with an Open Men's team and a technical first Development Academy focused on movement and game intelligence.",
  ogImage: "/og/home.png", // optional: make sure this exists in /public/og/home.jpg
};
---

<BaseLayout pageTitle={pageTitle} seo={seo}>
  <AcademyHero />
  <Philosophy />
  <Evaluation />
  <Programs />
  <Cta
    title="Start Your Development<br />Journey Today"
    body="Join South Van FC and unlock your full potential. Discover the right program or book a personalised evaluation."
    links={[
      {
        href: "/academy/player-evaluation",
        label: "Request Player Evaluation",
        style: "navy",
      },
      {
        href: "/our-coaches",
        label: "Meet the Coaches",
        style: "outline-navy",
      },
    ]}
  />
</BaseLayout>
