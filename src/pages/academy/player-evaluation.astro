---
import EvalHero from "../../components/PlayerEval/EvalHero.astro";
import EvalMeta from "../../components/PlayerEval/EvalMeta.astro";
import EvalProcess from "../../components/PlayerEval/EvalProcess.astro";
import EvalRequestForm from "../../components/PlayerEval/EvalRequestForm.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const seo = {
  title: "Player Evaluation | South Van FC Development Academy Vancouver",
  description:
    "Book a personalised player evaluation with South Van FC Academy. Our coaches assess your technical skills, tactical understanding, and movement to design your individual development plan.",
  keywords:
    "soccer player evaluation Vancouver, football tryout Vancouver, player assessment Vancouver, soccer skills assessment, South Van FC evaluation, academy evaluation Vancouver",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://www.southvanfc.com/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Academy",
      item: "https://www.southvanfc.com/academy/",
    },
    {
      "@type": "ListItem",
      position: 3,
      name: "Player Evaluation",
      item: "https://www.southvanfc.com/academy/player-evaluation/",
    },
  ],
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Player Evaluation",
  provider: {
    "@type": "Organization",
    name: "South Van FC",
    url: "https://www.southvanfc.com",
  },
  description:
    "A personalised player evaluation session where South Van FC coaches assess technical skills, tactical understanding, and athletic development to create an individual training plan.",
  areaServed: {
    "@type": "Place",
    name: "Vancouver, BC, Canada",
  },
  url: "https://www.southvanfc.com/academy/player-evaluation/",
};
---

<BaseLayout seo={seo}>
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbSchema)}
  />
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(serviceSchema)}
  />
  <EvalHero />
  <EvalMeta />
  <EvalProcess />
  <div class="form-wrap">
    <div class="form-panel">
      <div class="panel-header">
        <h2 class="panel-title">Evaluation Request Form</h2>
        <p class="panel-sub">
          Complete all required fields. <strong>Optional</strong> fields help us personalise
          your session.
        </p>
      </div>
      <EvalRequestForm />
    </div>
  </div>
</BaseLayout>

<style>
  .eval-body {
    display: grid;
    grid-template-columns: 300px 1fr;
    background: #f7f8fc;
  }

  .form-panel {
    background: #fff;
    border-left: 1px solid #eef0f7;
    padding: 44px 72px 64px 44px;
  }
  .panel-header {
    margin-bottom: 4px;
  }
  .panel-title {
    font-family: "Inter Variable", sans-serif;
    font-size: 28px;
    letter-spacing: 1px;
    color: #011f4a;
    margin-bottom: 6px;
  }
  .panel-sub {
    font-size: 13px;
    color: #6b7a9e;
    line-height: 1.6;
  }
  .panel-sub strong {
    font-weight: 600;
    color: #3d4d6e;
  }

  @media (max-width: 1100px) {
    .form-panel {
      padding: 44px 40px 64px 32px;
    }
  }
  @media (max-width: 960px) {
    .eval-body {
      grid-template-columns: 1fr;
    }
    .form-panel {
      border-left: none;
      border-top: 1px solid #eef0f7;
      padding: 36px 28px 56px;
    }
  }
</style>
